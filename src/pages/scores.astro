---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// ── Fetch seasons ──────────────────────────────────────────────────────────
const { data: seasonRows, error: sErr } = await supabase
  .schema('scdfl')
  .from('seasons')
  .select('year')
  .order('year');

if (sErr) throw new Error(`Seasons query failed: ${sErr.message}`);

// ── Fetch all franchise identities (including historical) ──────────────────
const { data: allFranchises, error: fErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('sleeper_id, abbr, name, conf, colors, "from", "to"');

if (fErr || !allFranchises) throw new Error(`Franchises query failed: ${fErr?.message || 'No data returned'}`);

// ── Fetch all matchups (compact: only fields needed for scores UI) ─────────
const { data: matchupRows, error: mErr } = await supabase
  .schema('scdfl')
  .from('matchups')
  .select('year, week, matchup_id, game_type, roster_id_a, roster_id_b, score_a, score_b')
  .limit(1000);

if (mErr) throw new Error(`Matchups query failed: ${mErr.message}`);

// ── Fetch exhibitions with scores ──────────────────────────────────────────
const { data: exhibRows, error: eErr } = await supabase
  .schema('scdfl')
  .from('exhibitions')
  .select('id, year, week, team_a_slug, team_a_display_name, team_a_members, team_b_slug, team_b_display_name, team_b_members, exhibition_matchups(score_a, score_b)');

if (eErr) throw new Error(`Exhibitions query failed: ${eErr.message}`);

// ── Recap slug set: "year/slug" keys for matchups that have recap content ────
const allRecaps = await getCollection('recaps');
const recapSlugsArr: string[] = allRecaps.map(r => r.id); // e.g. "2024/04-bkb-tor"

// ── Build franchise identity map for client: sleeper_id → array of identities
type FranchiseIdentity = {
  abbr: string;
  name: string;
  from: number;
  to: number | null;
};
const franchiseIdentities: Record<string, FranchiseIdentity[]> = {};
for (const f of allFranchises) {
  const key = f.sleeper_id;
  if (!franchiseIdentities[key]) franchiseIdentities[key] = [];
  franchiseIdentities[key].push({
    abbr: f.abbr,
    name: f.name,
    from: f.from,
    to: f.to,
  });
}

// ── Build matchups data for client: { year: { week: [matchup, ...] } } ─────
type ClientMatchup = {
  matchup_id: number;
  game_type: number;
  roster_id_a: number;
  roster_id_b: number;
  score_a: number;
  score_b: number;
};
const matchupsData: Record<string, Record<string, ClientMatchup[]>> = {};
for (const m of matchupRows ?? []) {
  const yr = String(m.year);
  const wk = String(m.week);
  if (!matchupsData[yr]) matchupsData[yr] = {};
  if (!matchupsData[yr][wk]) matchupsData[yr][wk] = [];
  matchupsData[yr][wk].push({
    matchup_id: m.matchup_id,
    game_type: m.game_type,
    roster_id_a: m.roster_id_a,
    roster_id_b: m.roster_id_b,
    score_a: m.score_a ?? 0,
    score_b: m.score_b ?? 0,
  });
}

// ── Dynasty Bowl lookup: derived from week 17 game_type=1 matchups ──────────
function toRoman(n: number): string {
  const vals = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const syms = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let result = '';
  for (let i = 0; i < vals.length; i++) {
    while (n >= vals[i]) { result += syms[i]; n -= vals[i]; }
  }
  return result;
}

const dynastyBowls: Record<string, { winner: string; loser: string; label: string }> = {};
for (const m of matchupRows ?? []) {
  if (m.week !== 17 || m.game_type !== 1) continue;
  const aWins = m.score_a > m.score_b;
  const winnerSleeperId = String(aWins ? m.roster_id_a : m.roster_id_b);
  const loserSleeperId = String(aWins ? m.roster_id_b : m.roster_id_a);
  // Find franchise abbr for the championship year
  const winnerIdentity = franchiseIdentities[winnerSleeperId]?.find(
    f => f.from <= m.year && (f.to === null || f.to >= m.year)
  );
  const loserIdentity = franchiseIdentities[loserSleeperId]?.find(
    f => f.from <= m.year && (f.to === null || f.to >= m.year)
  );
  dynastyBowls[String(m.year)] = {
    winner: winnerIdentity?.abbr ?? '',
    loser: loserIdentity?.abbr ?? '',
    label: `Dynasty Bowl ${toRoman(m.year - 2020)}`,
  };
}

// ── Determine seasons list (descending) ─────────────────────────────────────
const sortedSeasons = (seasonRows ?? []).map(s => s.year).sort((a: number, b: number) => b - a);

const defaultSeasonYear = sortedSeasons
  .find((yr: number) => Object.keys(matchupsData[String(yr)] ?? {}).length > 0)
  ?? sortedSeasons[0];

// ── Determine default week (max numeric week in default season) ──────────────
const defaultWeekNum = Math.max(
  ...Object.keys(matchupsData[String(defaultSeasonYear)] ?? {}).map(Number)
);

// ── Exhibition data (compact form for client) ─────────────────────────────────
type ExhibEntry = {
  year: number;
  week: number;
  slug: string;
  displayNameA: string;
  displayNameB: string;
  scoreA: number;
  scoreB: number;
  membersA: string[];
  membersB: string[];
};
const exhibitionsData: ExhibEntry[] = (exhibRows ?? []).map((e: any) => {
  const scores = e.exhibition_matchups?.[0] ?? { score_a: 0, score_b: 0 };
  const [slugA, slugB] = [e.team_a_slug.toLowerCase(), e.team_b_slug.toLowerCase()].sort();
  const weekPad = String(e.week).padStart(2, '0');
  return {
    year: e.year,
    week: e.week,
    slug: `${weekPad}-${slugA}-${slugB}`,
    displayNameA: e.team_a_display_name,
    displayNameB: e.team_b_display_name,
    scoreA: scores.score_a ?? 0,
    scoreB: scores.score_b ?? 0,
    membersA: e.team_a_members,
    membersB: e.team_b_members,
  };
});
---

<Layout title="Scores" description="Week-by-week matchup scores for every season of the Sixth City Dynasty Football League.">

  <div style="max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 0;">

    <!-- Page header -->
    <div style="padding-bottom: 2.5rem; border-bottom: 1px solid var(--color-border);">
      <p class="section-label">Results</p>
      <h1 class="page-title">Scores</h1>
      <p class="page-subtitle" style="margin-top: 0.75rem;">
        Season and week-by-week matchup results across all six seasons of the SCDFL.
      </p>
    </div>

    <!-- Controls -->
    <div style="display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap;">

      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
        <label for="season-select" style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">Season</label>
        <select id="season-select" style="font-family: var(--font-body); font-size: 0.9rem; color: var(--color-text-primary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 0.5rem 2rem 0.5rem 0.75rem; appearance: none; -webkit-appearance: none; background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path d=%22M0 0l5 6 5-6z%22 fill=%22%23888%22/></svg>'); background-repeat: no-repeat; background-position: right 0.6rem center; cursor: pointer; min-width: 140px;">
          {sortedSeasons.map((yr: number) => (
            <option
              value={yr}
              selected={yr === defaultSeasonYear}
              disabled={Object.keys(matchupsData[String(yr)] ?? {}).length === 0}
            >
              {yr} Season{Object.keys(matchupsData[String(yr)] ?? {}).length === 0 ? ' (no data)' : ''}
            </option>
          ))}
        </select>
      </div>

      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
        <label for="week-select" style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">Week</label>
        <select id="week-select" style="font-family: var(--font-body); font-size: 0.9rem; color: var(--color-text-primary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 0.5rem 2rem 0.5rem 0.75rem; appearance: none; -webkit-appearance: none; background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path d=%22M0 0l5 6 5-6z%22 fill=%22%23888%22/></svg>'); background-repeat: no-repeat; background-position: right 0.6rem center; cursor: pointer; min-width: 110px;">
          <!-- populated by JS -->
        </select>
      </div>

    </div>

    <!-- Scores grid -->
    <div id="scores-grid" style="margin-top: 2rem; padding-bottom: 4rem;"></div>

  </div>

</Layout>

<style>
  :global(.matchups-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 72ch;
  }

  :global(.matchup-card) {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  :global(.matchup-body) {
    display: flex;
    align-items: stretch;
  }

  :global(.matchup-teams) {
    flex: 1;
    min-width: 0;
  }

  :global(.recap-btn) {
    display: flex;
    align-items: center;
    padding: 0 1.1rem;
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
    border-left: 1px solid var(--color-border);
    color: var(--color-gold);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  :global(.team-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    transition: background-color 0.1s ease;
  }

  :global(.team-row + .team-row) {
    border-top: 1px solid var(--color-border);
  }

  :global(.team-row.winner) {
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  :global(.team-row.loser) {
    opacity: 0.55;
  }

  :global(.team-row.tied) {
    background-color: transparent;
  }

  :global(.team-logo) {
    width: 36px;
    height: 36px;
    object-fit: contain;
    flex-shrink: 0;
  }

  :global(.team-name) {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-primary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.team-score) {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    min-width: 3.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  :global(.winner .team-score) {
    color: var(--color-gold);
  }

  :global(.dynasty-bowl-banner) {
    background-color: var(--color-gold-surface);
    border-bottom: 1px solid var(--color-gold-glow);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 4rem;
  }

  :global(.no-data) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 3rem 0;
    text-align: center;
  }
</style>

<script define:vars={{ matchupsData, franchiseIdentities, dynastyBowls, recapSlugsArr, defaultSeasonYear, defaultWeekNum, exhibitionsData, sortedSeasons }}>
  const seasonSelect = document.getElementById('season-select');
  const weekSelect = document.getElementById('week-select');
  const grid = document.getElementById('scores-grid');

  const recapSlugs = new Set(recapSlugsArr); // "year/slug" keys

  function makeSlug(week, abbrA, abbrB) {
    const pad = String(week).padStart(2, '0');
    const [t1, t2] = [abbrA.toLowerCase(), abbrB.toLowerCase()].sort();
    return `${pad}-${t1}-${t2}`;
  }

  // ── Franchise identity lookup for a given year ──────────────────────────
  function getFranchise(sleeperId, year) {
    const identities = franchiseIdentities[String(sleeperId)];
    if (!identities) return { abbr: 'UNKNOWN', name: `Roster ${sleeperId}` };
    return identities.find(f => f.from <= year && (f.to === null || f.to >= year))
      ?? identities[identities.length - 1]; // fallback to latest identity
  }

  // ── Populate week dropdown for a given season ────────────────────────────
  function populateWeeks(year, selectedWeek) {
    const weeks = Object.keys(matchupsData[String(year)] ?? {})
      .map(Number)
      .sort((a, b) => a - b);

    weekSelect.innerHTML = weeks
      .map(w => `<option value="${w}"${w === selectedWeek ? ' selected' : ''}>Week ${w}</option>`)
      .join('');
  }

  // ── Exhibition team row with multiple logos ───────────────────────────────
  function exhibTeamRow(members, displayName, score, isWinner, isLoser) {
    const cls = isWinner ? 'winner' : isLoser ? 'loser' : 'tied';
    const logos = members.map(abbr =>
      `<img class="team-logo" src="/images/logos/${abbr}.png" alt="${abbr}"
            style="width:36px;height:36px;object-fit:contain;"
            onerror="this.style.display='none'" />`
    ).join('');
    return `
      <div class="team-row ${cls}">
        <span style="display:flex;gap:4px;flex-shrink:0;">${logos}</span>
        <span class="team-name">${displayName}</span>
        <span class="team-score">${score.toFixed(2)}</span>
      </div>`;
  }

  // ── Render matchups for a given season + week ────────────────────────────
  function renderScores(year, week) {
    // Exhibition games for this year/week
    const yearExhibs = (exhibitionsData ?? []).filter(e => e.year === year && e.week === week);

    let html = '';
    if (yearExhibs.length > 0) {
      html += '<p class="section-label" style="margin-bottom:0.5rem;">Exhibitions</p>'
        + '<div class="matchups-grid" style="margin-bottom:1.5rem;">';
      for (const e of yearExhibs) {
        const aWins = e.scoreA > e.scoreB;
        const bWins = e.scoreB > e.scoreA;
        html += `
          <a class="matchup-card" href="/games/${year}/${e.slug}">
            <div class="matchup-body">
              <div class="matchup-teams">
                ${exhibTeamRow(e.membersA, e.displayNameA, e.scoreA, aWins, bWins)}
                ${exhibTeamRow(e.membersB, e.displayNameB, e.scoreB, bWins, aWins)}
              </div>
            </div>
          </a>`;
      }
      html += `
      </div>
      <p class="section-label" style="margin-bottom:0.5rem;">Regular Season</p>`;
    }

    // Standard matchups — each row is already one game (both teams)
    const matchups = matchupsData[String(year)]?.[String(week)] ?? [];

    if (matchups.length === 0 && yearExhibs.length === 0) {
      grid.innerHTML = '<p class="no-data">No data available for this selection.</p>';
      return;
    }

    // Filter out invalid matchup_ids and sort
    const validMatchups = matchups
      .filter(m => m.matchup_id && m.matchup_id > 0)
      .sort((a, b) => a.matchup_id - b.matchup_id);

    html += '<div class="matchups-grid">';
    for (const m of validMatchups) {
      const fA = getFranchise(m.roster_id_a, year);
      const fB = getFranchise(m.roster_id_b, year);

      const aWins = m.score_a > m.score_b;
      const bWins = m.score_b > m.score_a;

      // Check for Dynasty Bowl banner (Week 17 only)
      let banner = '';
      if (week === 17) {
        const db = dynastyBowls[String(year)];
        if (db) {
          if ((fA.abbr === db.winner || fA.abbr === db.loser) &&
              (fB.abbr === db.winner || fB.abbr === db.loser)) {
            banner = `<div class="dynasty-bowl-banner">${db.label}</div>`;
          }
        }
      }

      // Slug uses effective abbrs for URL — look up identity for given year
      const activeA = getFranchise(m.roster_id_a, year);
      const activeB = getFranchise(m.roster_id_b, year);
      const slug = makeSlug(week, activeA.abbr, activeB.abbr);
      const gameUrl = `/games/${year}/${slug}`;
      const hasRecap = recapSlugs.has(`${year}/${slug}`);

      html += `
        <a class="matchup-card" href="${gameUrl}">
          ${banner}
          <div class="matchup-body">
            <div class="matchup-teams">
              ${teamRow(fA, m.score_a, aWins, bWins)}
              ${teamRow(fB, m.score_b, bWins, aWins)}
            </div>
            ${hasRecap ? `<div class="recap-btn">Recap&nbsp;→</div>` : ''}
          </div>
        </a>`;
    }
    html += '</div>';

    grid.innerHTML = html;
  }

  function teamRow(franchise, score, isWinner, isLoser) {
    const cls = isWinner ? 'winner' : isLoser ? 'loser' : 'tied';

    return `
      <div class="team-row ${cls}">
        <img class="team-logo"
             src="/images/logos/${franchise.abbr}.png"
             alt="${franchise.name}"
             onerror="this.style.display='none'" />
        <span class="team-name">${franchise.name}</span>
        <span class="team-score">${score.toFixed(2)}</span>
      </div>`;
  }

  // ── Wire up event listeners ──────────────────────────────────────────────
  seasonSelect.addEventListener('change', () => {
    const year = Number(seasonSelect.value);
    const weeks = Object.keys(matchupsData[String(year)] ?? {}).map(Number).sort((a, b) => a - b);
    const latestWeek = weeks[weeks.length - 1] ?? 1;
    populateWeeks(year, latestWeek);
    renderScores(year, latestWeek);
  });

  weekSelect.addEventListener('change', () => {
    renderScores(Number(seasonSelect.value), Number(weekSelect.value));
  });

  // ── Initial render ───────────────────────────────────────────────────────
  populateWeeks(defaultSeasonYear, defaultWeekNum);
  renderScores(defaultSeasonYear, defaultWeekNum);
</script>
