---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import config from '../data/config.json';
import franchisesJson from '../data/franchises.json';
import seasonsJson from '../data/seasons.json';
import exhibitionsJson from '../data/raw/exhibitions.json';

// ── Load all matchup files at build time ────────────────────────────────────
const matchupGlob = import.meta.glob('/src/data/raw/*-matchups.json', { eager: true });

// Compact form: strip players/starters/player_points arrays — keep only what the UI needs
type MatchupEntry = { roster_id: number; matchup_id: number; score: number };
const matchupsData: Record<string, Record<string, MatchupEntry[]>> = {};

for (const [path, mod] of Object.entries(matchupGlob)) {
  const m = path.match(/(\d{4})-matchups/);
  if (!m) continue;
  const year = m[1];
  const raw = (mod as { default: Record<string, any[]> }).default;
  const weeks: Record<string, MatchupEntry[]> = {};
  for (const [week, entries] of Object.entries(raw)) {
    weeks[week] = entries.map(e => ({
      roster_id: e.roster_id,
      matchup_id: e.matchup_id,
      score: e.custom_points != null ? e.custom_points : e.points,
    }));
  }
  matchupsData[year] = weeks;
}

// ── Franchise lookup: roster_id (= f.id) → { name, abbr } ──────────────────
type FranchiseEntry = {
  name: string;
  abbr: string;
  founded: number;
  predecessorAbbr: string | null;
  rebrands: Array<{ year: number; name: string }>;
};
const franchiseMap: Record<number, FranchiseEntry> = {};
for (const f of franchisesJson) {
  franchiseMap[f.id] = {
    name: f.name,
    abbr: f.abbr,
    founded: f.founded,
    predecessorAbbr: ('predecessor_abbr' in f ? (f as any).predecessor_abbr : null) ?? null,
    rebrands: (f.rebrands ?? []) as Array<{ year: number; name: string }>,
  };
}

// ── Recap slug set: "year/slug" keys for matchups that have recap content ────
const allRecaps = await getCollection('recaps');
const recapSlugsArr: string[] = allRecaps.map(r => r.id); // e.g. "2024/04-bkb-tor"

// ── Dynasty Bowl lookup: year → { winner, loser, label } ────────────────────
const dynastyBowls: Record<string, { winner: string; loser: string; label: string }> = {};
for (const s of seasonsJson) {
  dynastyBowls[String(s.year)] = {
    winner: s.dynasty_bowl.winner,
    loser: s.dynasty_bowl.loser,
    label: s.dynasty_bowl.label,
  };
}

// ── Determine default season (latest year with data) ────────────────────────
const sortedSeasons = [...config.seasons].sort((a, b) => b.year - a.year);

const defaultSeasonYear = sortedSeasons
  .find(s => Object.keys(matchupsData[String(s.year)] ?? {}).length > 0)
  ?.year ?? sortedSeasons[0].year;

// ── Determine default week (max numeric week in default season) ──────────────
const defaultWeekNum = Math.max(
  ...Object.keys(matchupsData[String(defaultSeasonYear)] ?? {}).map(Number)
);

// ── Exhibition data (compact form for client) ─────────────────────────────────
type ExhibEntry = {
  year: number;
  week: number;
  slug: string;
  displayNameA: string;
  displayNameB: string;
  scoreA: number;
  scoreB: number;
  membersA: string[];
  membersB: string[];
};
const exhibitionsData: ExhibEntry[] = (exhibitionsJson as any[]).map((e: any) => ({
  year: e.year,
  week: e.week,
  slug: e.slug,
  displayNameA: e.team_a.display_name,
  displayNameB: e.team_b.display_name,
  scoreA: e.team_a.score,
  scoreB: e.team_b.score,
  membersA: e.team_a.members,
  membersB: e.team_b.members,
}));
---

<Layout title="Scores" description="Week-by-week matchup scores for every season of the Sixth City Dynasty Football League.">

  <div style="max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 0;">

    <!-- Page header -->
    <div style="padding-bottom: 2.5rem; border-bottom: 1px solid var(--color-border);">
      <p class="section-label">Results</p>
      <h1 class="page-title">Scores</h1>
      <p class="page-subtitle" style="margin-top: 0.75rem;">
        Season and week-by-week matchup results across all six seasons of the SCDFL.
      </p>
    </div>

    <!-- Controls -->
    <div style="display: flex; gap: 1rem; margin-top: 2rem; flex-wrap: wrap;">

      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
        <label for="season-select" style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">Season</label>
        <select id="season-select" style="font-family: var(--font-body); font-size: 0.9rem; color: var(--color-text-primary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 0.5rem 2rem 0.5rem 0.75rem; appearance: none; -webkit-appearance: none; background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path d=%22M0 0l5 6 5-6z%22 fill=%22%23888%22/></svg>'); background-repeat: no-repeat; background-position: right 0.6rem center; cursor: pointer; min-width: 140px;">
          {sortedSeasons.map(s => (
            <option
              value={s.year}
              selected={s.year === defaultSeasonYear}
              disabled={Object.keys(matchupsData[String(s.year)] ?? {}).length === 0}
            >
              {s.year} Season{Object.keys(matchupsData[String(s.year)] ?? {}).length === 0 ? ' (no data)' : ''}
            </option>
          ))}
        </select>
      </div>

      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
        <label for="week-select" style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">Week</label>
        <select id="week-select" style="font-family: var(--font-body); font-size: 0.9rem; color: var(--color-text-primary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 0.5rem 2rem 0.5rem 0.75rem; appearance: none; -webkit-appearance: none; background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path d=%22M0 0l5 6 5-6z%22 fill=%22%23888%22/></svg>'); background-repeat: no-repeat; background-position: right 0.6rem center; cursor: pointer; min-width: 110px;">
          <!-- populated by JS -->
        </select>
      </div>

    </div>

    <!-- Scores grid -->
    <div id="scores-grid" style="margin-top: 2rem; padding-bottom: 4rem;"></div>

  </div>

</Layout>

<style>
  :global(.matchups-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 72ch;
  }

  :global(.matchup-card) {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  :global(.matchup-body) {
    display: flex;
    align-items: stretch;
  }

  :global(.matchup-teams) {
    flex: 1;
    min-width: 0;
  }

  :global(.recap-btn) {
    display: flex;
    align-items: center;
    padding: 0 1.1rem;
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
    border-left: 1px solid var(--color-border);
    color: var(--color-gold);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  :global(.team-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    transition: background-color 0.1s ease;
  }

  :global(.team-row + .team-row) {
    border-top: 1px solid var(--color-border);
  }

  :global(.team-row.winner) {
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  :global(.team-row.loser) {
    opacity: 0.55;
  }

  :global(.team-row.tied) {
    background-color: transparent;
  }

  :global(.team-logo) {
    width: 36px;
    height: 36px;
    object-fit: contain;
    flex-shrink: 0;
  }

  :global(.team-name) {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-primary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.team-score) {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    min-width: 3.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  :global(.winner .team-score) {
    color: var(--color-gold);
  }

  :global(.dynasty-bowl-banner) {
    background-color: var(--color-gold-surface);
    border-bottom: 1px solid var(--color-gold-glow);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 4rem;
  }

  :global(.no-data) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 3rem 0;
    text-align: center;
  }
</style>

<script define:vars={{ matchupsData, franchiseMap, dynastyBowls, recapSlugsArr, defaultSeasonYear, defaultWeekNum, exhibitionsData }}>
  const seasonSelect = document.getElementById('season-select');
  const weekSelect = document.getElementById('week-select');
  const grid = document.getElementById('scores-grid');

  const recapSlugs = new Set(recapSlugsArr); // "year/slug" keys

  function makeSlug(week, abbrA, abbrB) {
    const pad = String(week).padStart(2, '0');
    const [t1, t2] = [abbrA.toLowerCase(), abbrB.toLowerCase()].sort();
    return `${pad}-${t1}-${t2}`;
  }

  // ── Populate week dropdown for a given season ────────────────────────────
  function populateWeeks(year, selectedWeek) {
    const weeks = Object.keys(matchupsData[String(year)] ?? {})
      .map(Number)
      .sort((a, b) => a - b);

    weekSelect.innerHTML = weeks
      .map(w => `<option value="${w}"${w === selectedWeek ? ' selected' : ''}>Week ${w}</option>`)
      .join('');
  }

  // ── Exhibition team row with multiple logos ───────────────────────────────
  function exhibTeamRow(members, displayName, score, isWinner, isLoser) {
    const cls = isWinner ? 'winner' : isLoser ? 'loser' : 'tied';
    const logos = members.map(abbr =>
      `<img class="team-logo" src="/images/logos/${abbr}.png" alt="${abbr}"
            style="width:36px;height:36px;object-fit:contain;"
            onerror="this.style.display='none'" />`
    ).join('');
    return `
      <div class="team-row ${cls}">
        <span style="display:flex;gap:4px;flex-shrink:0;">${logos}</span>
        <span class="team-name">${displayName}</span>
        <span class="team-score">${score.toFixed(2)}</span>
      </div>`;
  }

  // ── Render matchups for a given season + week ────────────────────────────
  function renderScores(year, week) {
    // Exhibition games for this year/week
    const yearExhibs = (exhibitionsData ?? []).filter(e => e.year === year && e.week === week);

    let html = '';
    if (yearExhibs.length > 0) {
      html += '<p class="section-label" style="margin-bottom:0.5rem;">Exhibitions</p>'
        + '<div class="matchups-grid" style="margin-bottom:1.5rem;">';
      for (const e of yearExhibs) {
        const aWins = e.scoreA > e.scoreB;
        const bWins = e.scoreB > e.scoreA;
        html += `
          <a class="matchup-card" href="/games/${year}/${e.slug}">
            <div class="matchup-body">
              <div class="matchup-teams">
                ${exhibTeamRow(e.membersA, e.displayNameA, e.scoreA, aWins, bWins)}
                ${exhibTeamRow(e.membersB, e.displayNameB, e.scoreB, bWins, aWins)}
              </div>
            </div>
          </a>`;
      }
      html += `
      </div>
      <p class="section-label" style="margin-bottom:0.5rem;">Regular Season</p>`;
    }

    // Standard matchups
    const entries = matchupsData[String(year)]?.[String(week)] ?? [];

    if (entries.length === 0 && yearExhibs.length === 0) {
      grid.innerHTML = '<p class="no-data">No data available for this selection.</p>';
      return;
    }

    // Group by matchup_id — skip null/0 entries (bye teams in playoff weeks)
    const grouped = {};
    for (const entry of entries) {
      if (!entry.matchup_id) continue;
      if (!grouped[entry.matchup_id]) grouped[entry.matchup_id] = [];
      grouped[entry.matchup_id].push(entry);
    }

    const matchupIds = Object.keys(grouped)
      .map(Number)
      .filter(n => n > 0 && !isNaN(n))
      .sort((a, b) => a - b);

    html += '<div class="matchups-grid">';
    for (const mid of matchupIds) {
      const [teamA, teamB] = grouped[mid];
      if (!teamA || !teamB) continue;

      const scoreA = teamA.score;
      const scoreB = teamB.score;
      const aWins = scoreA > scoreB;
      const bWins = scoreB > scoreA;

      const fA = franchiseMap[teamA.roster_id] ?? { name: `Roster ${teamA.roster_id}`, abbr: 'UNKNOWN', founded: 2021, predecessorAbbr: null, rebrands: [] };
      const fB = franchiseMap[teamB.roster_id] ?? { name: `Roster ${teamB.roster_id}`, abbr: 'UNKNOWN', founded: 2021, predecessorAbbr: null, rebrands: [] };

      // Check for Dynasty Bowl banner (Week 17 only)
      let banner = '';
      if (week === 17) {
        const db = dynastyBowls[String(year)];
        if (db) {
          const abbrA = getEffectiveAbbr(fA, year);
          const abbrB = getEffectiveAbbr(fB, year);
          if ((abbrA === db.winner || abbrA === db.loser) &&
              (abbrB === db.winner || abbrB === db.loser)) {
            banner = `<div class="dynasty-bowl-banner">${db.label}</div>`;
          }
        }
      }

      const slug = makeSlug(week, fA.abbr, fB.abbr);
      const gameUrl = `/games/${year}/${slug}`;
      const hasRecap = recapSlugs.has(`${year}/${slug}`);

      html += `
        <a class="matchup-card" href="${gameUrl}">
          ${banner}
          <div class="matchup-body">
            <div class="matchup-teams">
              ${teamRow(fA, scoreA, aWins, bWins, year)}
              ${teamRow(fB, scoreB, bWins, aWins, year)}
            </div>
            ${hasRecap ? `<div class="recap-btn">Recap&nbsp;→</div>` : ''}
          </div>
        </a>`;
    }
    html += '</div>';

    grid.innerHTML = html;
  }

  function getEffectiveAbbr(franchise, year) {
    if (franchise.founded !== 2021 && year < franchise.founded) {
      return franchise.predecessorAbbr ?? franchise.abbr;
    }
    return franchise.abbr;
  }

  function teamRow(franchise, score, isWinner, isLoser, year) {
    const cls = isWinner ? 'winner' : isLoser ? 'loser' : 'tied';

    // Adopted teams (founded != 2021) use predecessor identity in pre-adoption seasons
    let name = franchise.name;
    let logoAbbr = franchise.abbr;
    if (franchise.founded !== 2021 && year < franchise.founded) {
      const rebrand = franchise.rebrands.find(r => r.year === year);
      if (rebrand) name = rebrand.name;
      if (franchise.predecessorAbbr) logoAbbr = franchise.predecessorAbbr;
    }

    return `
      <div class="team-row ${cls}">
        <img class="team-logo"
             src="/images/logos/${logoAbbr}.png"
             alt="${name}"
             onerror="this.style.display='none'" />
        <span class="team-name">${name}</span>
        <span class="team-score">${score.toFixed(2)}</span>
      </div>`;
  }

  // ── Wire up event listeners ──────────────────────────────────────────────
  seasonSelect.addEventListener('change', () => {
    const year = Number(seasonSelect.value);
    const weeks = Object.keys(matchupsData[String(year)] ?? {}).map(Number).sort((a, b) => a - b);
    const latestWeek = weeks[weeks.length - 1] ?? 1;
    populateWeeks(year, latestWeek);
    renderScores(year, latestWeek);
  });

  weekSelect.addEventListener('change', () => {
    renderScores(Number(seasonSelect.value), Number(weekSelect.value));
  });

  // ── Initial render ───────────────────────────────────────────────────────
  populateWeeks(defaultSeasonYear, defaultWeekNum);
  renderScores(defaultSeasonYear, defaultWeekNum);
</script>
