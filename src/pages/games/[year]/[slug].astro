---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';
import { mapStartersToSlots, mapExhibitionStartersToSlots } from '../../../lib/lineup';

// ── Static paths — self-contained, no module-scope variable access ────────────
export async function getStaticPaths() {
  const { supabase: sb } = await import('../../../lib/supabase');

  // Fetch all matchups and franchise identities in parallel
  const [matchupsRes, franchisesRes, exhibitionsRes] = await Promise.all([
    sb.schema('scdfl').from('matchups')
      .select('year, week, roster_id_a, roster_id_b')
      .limit(1000),
    sb.schema('scdfl').from('franchises')
      .select('sleeper_id, abbr, "from", "to"'),
    sb.schema('scdfl').from('exhibitions')
      .select('id, year, week, exhib_type, team_a_slug, team_a_display_name, team_a_members, team_b_slug, team_b_display_name, team_b_members'),
  ]);

  const matchups = matchupsRes.data ?? [];
  const franchises = franchisesRes.data ?? [];
  const exhibitions = exhibitionsRes.data ?? [];

  // Resolve roster_id → effective abbr for a given year
  function getEffectiveAbbr(rosterId: number, year: number): string | null {
    const sleeperId = String(rosterId);
    const identity = franchises.find(
      (f: any) => f.sleeper_id === sleeperId && f.from <= year && (f.to === null || f.to >= year)
    );
    return identity?.abbr ?? null;
  }

  const paths: any[] = [];

  // Regular game paths
  for (const m of matchups) {
    const abbrA = getEffectiveAbbr(m.roster_id_a, m.year);
    const abbrB = getEffectiveAbbr(m.roster_id_b, m.year);
    if (!abbrA || !abbrB) continue;

    const weekPad = String(m.week).padStart(2, '0');
    const [t1, t2] = [abbrA.toLowerCase(), abbrB.toLowerCase()].sort();
    const slug = `${weekPad}-${t1}-${t2}`;

    paths.push({
      params: { year: String(m.year), slug },
      props: { year: m.year, week: m.week, rosterIdA: m.roster_id_a, rosterIdB: m.roster_id_b },
    });
  }

  // Exhibition paths
  for (const ex of exhibitions) {
    const weekPad = String(ex.week).padStart(2, '0');
    const [s1, s2] = [ex.team_a_slug.toLowerCase(), ex.team_b_slug.toLowerCase()].sort();
    const slug = `${weekPad}-${s1}-${s2}`;

    paths.push({
      params: { year: String(ex.year), slug },
      props: {
        year: ex.year,
        week: ex.week,
        isExhibition: true,
        exhibitionId: ex.id,
        exhib: ex,
      },
    });
  }

  return paths;
}

// ── Page component ────────────────────────────────────────────────────────────
const { year, week, isExhibition, exhibitionId, exhib, rosterIdA, rosterIdB } = Astro.props;
const { slug } = Astro.params;

let fA: any, fB: any, effA: any, effB: any, scoreA: number, scoreB: number, aWins: boolean, bWins: boolean;
let winsA = 0, lossesA = 0, winsB = 0, lossesB = 0;
let lineupA: any[], lineupB: any[];
let pageTitle: string;
let allPlayerIds: string[] = [];

if (isExhibition && exhib) {
  // ── Exhibition game ─────────────────────────────────────────────────────────
  const { data: exhibMatchup } = await supabase
    .schema('scdfl').from('exhibition_matchups')
    .select('score_a, score_b, starters_a, starter_points_a, starters_b, starter_points_b')
    .eq('exhibition_id', exhibitionId)
    .single();

  scoreA = Number(exhibMatchup?.score_a ?? 0);
  scoreB = Number(exhibMatchup?.score_b ?? 0);
  aWins = scoreA > scoreB;
  bWins = scoreB > scoreA;

  const startersA: string[] = exhibMatchup?.starters_a ?? [];
  const starterPointsA: number[] = (exhibMatchup?.starter_points_a ?? []).map(Number);
  const startersB: string[] = exhibMatchup?.starters_b ?? [];
  const starterPointsB: number[] = (exhibMatchup?.starter_points_b ?? []).map(Number);

  lineupA = mapExhibitionStartersToSlots(startersA, starterPointsA, exhib.exhib_type);
  lineupB = mapExhibitionStartersToSlots(startersB, starterPointsB, exhib.exhib_type);

  effA = { name: exhib.team_a_display_name, logoAbbr: exhib.team_a_members[0] ?? 'UNKNOWN', members: exhib.team_a_members };
  effB = { name: exhib.team_b_display_name, logoAbbr: exhib.team_b_members[0] ?? 'UNKNOWN', members: exhib.team_b_members };

  allPlayerIds = [...startersA, ...startersB].filter(Boolean);
  pageTitle = `${effA.name} vs ${effB.name}`;
} else {
  // ── Regular game ────────────────────────────────────────────────────────────

  // Fetch matchup data, franchise identities, and records in parallel
  const [matchupRes, franchisesRes, recordsRes] = await Promise.all([
    supabase.schema('scdfl').from('matchups')
      .select('*')
      .eq('year', year).eq('week', week)
      .or(`roster_id_a.eq.${rosterIdA},roster_id_b.eq.${rosterIdA}`)
      .limit(1)
      .single(),
    supabase.schema('scdfl').from('franchises')
      .select('sleeper_id, abbr, name, conf, colors, "from", "to"')
      .lte('"from"', year)
      .or(`"to".gte.${year},"to".is.null`),
    supabase.schema('scdfl').from('matchups')
      .select('roster_id_a, roster_id_b, score_a, score_b')
      .eq('year', year).eq('game_type', 0).lte('week', week)
      .or(`roster_id_a.in.(${rosterIdA},${rosterIdB}),roster_id_b.in.(${rosterIdA},${rosterIdB})`)
      .limit(500),
  ]);

  const matchup = matchupRes.data;
  const franchises = franchisesRes.data ?? [];
  const recordRows = recordsRes.data ?? [];

  // Resolve franchise identity for each team
  const sleeperA = String(rosterIdA);
  const sleeperB = String(rosterIdB);
  fA = franchises.find((f: any) => f.sleeper_id === sleeperA);
  fB = franchises.find((f: any) => f.sleeper_id === sleeperB);

  // Determine which side of the matchup row corresponds to which roster
  // The matchup row may have roster_id_a = rosterIdA or roster_id_b = rosterIdA
  const aIsFirst = matchup?.roster_id_a === rosterIdA;
  scoreA = Number(aIsFirst ? matchup?.score_a : matchup?.score_b) || 0;
  scoreB = Number(aIsFirst ? matchup?.score_b : matchup?.score_a) || 0;
  aWins = scoreA > scoreB;
  bWins = scoreB > scoreA;

  // Records through this week (regular season only)
  for (const row of recordRows) {
    const rA = row.roster_id_a;
    const rB = row.roster_id_b;
    const sA = Number(row.score_a);
    const sB = Number(row.score_b);

    // Team A record
    if (rA === rosterIdA || rB === rosterIdA) {
      const myScore = rA === rosterIdA ? sA : sB;
      const oppScore = rA === rosterIdA ? sB : sA;
      if (myScore > oppScore) winsA++; else if (oppScore > myScore) lossesA++;
    }
    // Team B record
    if (rA === rosterIdB || rB === rosterIdB) {
      const myScore = rA === rosterIdB ? sA : sB;
      const oppScore = rA === rosterIdB ? sB : sA;
      if (myScore > oppScore) winsB++; else if (oppScore > myScore) lossesB++;
    }
  }

  // Effective identity
  effA = { name: fA?.name ?? 'Unknown', logoAbbr: fA?.abbr ?? 'UNKNOWN' };
  effB = { name: fB?.name ?? 'Unknown', logoAbbr: fB?.abbr ?? 'UNKNOWN' };

  // Lineups — orient starters to match rosterIdA/rosterIdB
  const startersA: string[] = (aIsFirst ? matchup?.starters_a : matchup?.starters_b) ?? [];
  const starterPointsA: number[] = ((aIsFirst ? matchup?.starter_points_a : matchup?.starter_points_b) ?? []).map(Number);
  const startersB: string[] = (aIsFirst ? matchup?.starters_b : matchup?.starters_a) ?? [];
  const starterPointsB: number[] = ((aIsFirst ? matchup?.starter_points_b : matchup?.starter_points_a) ?? []).map(Number);

  lineupA = mapStartersToSlots(startersA, starterPointsA, year, week);
  lineupB = mapStartersToSlots(startersB, starterPointsB, year, week);

  allPlayerIds = [...startersA, ...startersB].filter(Boolean);
  pageTitle = `${effA.name} vs ${effB.name}`;
}

// ── Player metadata ───────────────────────────────────────────────────────────
const playerMap = new Map<string, { full_name: string; espn_id: string | null }>();

if (allPlayerIds.length > 0) {
  const { data: players } = await supabase
    .schema('scdfl').from('v_players')
    .select('player_id, first_name, last_name, fantasy_positions, espn_id')
    .in('player_id', allPlayerIds)
    .limit(100);

  for (const p of players ?? []) {
    const fullName = [p.first_name, p.last_name].filter(Boolean).join(' ') || p.player_id;
    playerMap.set(p.player_id, {
      full_name: fullName,
      espn_id: p.espn_id ?? null,
    });
  }
}

function playerName(id: string) { return playerMap.get(id)?.full_name || id; }
function espnHeadshotUrl(id: string) {
  const espnId = playerMap.get(id)?.espn_id;
  return espnId ? `https://a.espncdn.com/i/headshots/nfl/players/full/${espnId}.png` : null;
}

// ── Recap ─────────────────────────────────────────────────────────────────────
const allRecaps = await getCollection('recaps');
const recap = allRecaps.find(r => r.id === `${year}/${slug}`) ?? null;
let Content: any = null;
if (recap) {
  const rendered = await render(recap);
  Content = rendered.Content;
  pageTitle = recap.data.title;
}
---

<Layout title={pageTitle} description={`Week ${week}, ${year} — ${effA.name} vs ${effB.name}`}>

  <div style="max-width: 760px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">

    <a href="/scores" style="font-family: var(--font-body); font-size: 0.72rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;">← Scores</a>

    {isExhibition ? (
      <p class="section-label" style="margin-top: 1.75rem;">Exhibition &middot; Week {week} &middot; {year}</p>
    ) : (
      <p class="section-label" style="margin-top: 1.75rem;">Week {week} &middot; {year} Season</p>
    )}

    <!-- Score block -->
    <div style="border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; margin-top: 0.75rem;">

      <div class:list={['game-team', aWins ? 'winner' : bWins ? 'loser' : 'tied']}>
        {isExhibition && effA.members ? (
          <div style="display: flex; gap: 4px; flex-shrink: 0;">
            {effA.members.map((abbr: string) => (
              <img src={`/images/logos/${abbr}.png`} alt={abbr} width="36" height="36"
                   style="object-fit: contain;" onerror="this.style.display='none'" />
            ))}
          </div>
        ) : (
          <img src={`/images/logos/${effA.logoAbbr}.png`} alt={effA.name} width="52" height="52"
               style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
        )}
        <div style="flex: 1; min-width: 0;">
          <div class="game-team-name">{effA.name}</div>
          {!isExhibition && <div class="game-record">{winsA}–{lossesA}</div>}
        </div>
        <span class:list={['game-score', aWins ? 'winner' : '']}>{scoreA.toFixed(2)}</span>
      </div>

      <div style="height: 1px; background: var(--color-border);"></div>

      <div class:list={['game-team', bWins ? 'winner' : aWins ? 'loser' : 'tied']}>
        {isExhibition && effB.members ? (
          <div style="display: flex; gap: 4px; flex-shrink: 0;">
            {effB.members.map((abbr: string) => (
              <img src={`/images/logos/${abbr}.png`} alt={abbr} width="36" height="36"
                   style="object-fit: contain;" onerror="this.style.display='none'" />
            ))}
          </div>
        ) : (
          <img src={`/images/logos/${effB.logoAbbr}.png`} alt={effB.name} width="52" height="52"
               style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
        )}
        <div style="flex: 1; min-width: 0;">
          <div class="game-team-name">{effB.name}</div>
          {!isExhibition && <div class="game-record">{winsB}–{lossesB}</div>}
        </div>
        <span class:list={['game-score', bWins ? 'winner' : '']}>{scoreB.toFixed(2)}</span>
      </div>

    </div>

    <!-- Starting Lineups -->
    <div style="margin-top: 2rem;">
      <p class="section-label">Starting Lineups</p>
      <div class="lineup-grid">

        <!-- Column headers -->
        <div class="lineup-col-header lineup-col-header-a">
          {isExhibition && effA.members ? (
            <div style="display: flex; gap: 2px;">
              {effA.members.map((abbr: string) => (
                <img src={`/images/logos/${abbr}.png`} alt={abbr} width="18" height="18"
                     style="object-fit: contain;" onerror="this.style.display='none'" />
              ))}
            </div>
          ) : (
            <img src={`/images/logos/${effA.logoAbbr}.png`} alt="" width="22" height="22"
                 style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
          )}
          <span>{effA.name}</span>
        </div>
        <div class="lineup-col-header lineup-col-header-b">
          <span>{effB.name}</span>
          {isExhibition && effB.members ? (
            <div style="display: flex; gap: 2px;">
              {effB.members.map((abbr: string) => (
                <img src={`/images/logos/${abbr}.png`} alt={abbr} width="18" height="18"
                     style="object-fit: contain;" onerror="this.style.display='none'" />
              ))}
            </div>
          ) : (
            <img src={`/images/logos/${effB.logoAbbr}.png`} alt="" width="22" height="22"
                 style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
          )}
        </div>

        <!-- Roster rows -->
        {lineupA.map((slotA, i) => {
          const slotB = lineupB[i];
          if (!slotA.visible) return null;
          return (
            <>
              <div
                class="lineup-row lineup-row-a"
                style={`--slot-surface: var(--color-${slotA.colorVar}-surface); --slot-glow: var(--color-${slotA.colorVar}-glow);`}
              >
                <span class="lineup-pos">{slotA.position}</span>
                <span class="lineup-thumb">
                  {espnHeadshotUrl(slotA.playerId)
                    ? <img src={espnHeadshotUrl(slotA.playerId)!} alt={playerName(slotA.playerId)} width="28" height="28" loading="lazy" decoding="async" onerror="this.src='/images/player-placeholder.png';this.onerror=null;" />
                    : null}
                </span>
                <span class="lineup-name">{playerName(slotA.playerId)}</span>
                <span class="lineup-score">{slotA.points.toFixed(2)}</span>
              </div>
              <div
                class="lineup-row lineup-row-b"
                style={`--slot-surface: var(--color-${slotB.colorVar}-surface); --slot-glow: var(--color-${slotB.colorVar}-glow);`}
              >
                <span class="lineup-pos">{slotB.position}</span>
                <span class="lineup-thumb">
                  {espnHeadshotUrl(slotB.playerId)
                    ? <img src={espnHeadshotUrl(slotB.playerId)!} alt={playerName(slotB.playerId)} width="28" height="28" loading="lazy" decoding="async" onerror="this.src='/images/player-placeholder.png';this.onerror=null;" />
                    : null}
                </span>
                <span class="lineup-name">{playerName(slotB.playerId)}</span>
                <span class="lineup-score">{slotB.points.toFixed(2)}</span>
              </div>
            </>
          );
        })}

      </div>
    </div>

    <!-- Recap (only rendered when a file exists) -->
    {recap && (
      <div style="margin-top: 3.5rem;">
        <h1 class="page-title" style="margin: 0;">{recap.data.title}</h1>
        {recap.data.subtitle && (
          <p style="font-family: var(--font-body); font-size: 1.05rem; color: var(--color-text-muted); margin: 0.6rem 0 0; line-height: 1.5;">{recap.data.subtitle}</p>
        )}
        <p style="font-family: var(--font-body); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); margin: 1rem 0 0;">
          {recap.data.date}
        </p>
        <hr style="border: none; border-top: 1px solid var(--color-border); margin: 1.5rem 0;" />
        <div class="recap-body" style="text-align: justify;">
          {Content && <Content />}
        </div>
      </div>
    )}

  </div>

</Layout>

<style>
  .game-team {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .game-team.winner {
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .game-team.loser {
    opacity: 0.55;
  }

  .game-team-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .game-record {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
  }

  .game-score {
    font-family: var(--font-body);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 4.5rem;
    text-align: right;
  }

  .game-score.winner {
    color: var(--color-gold);
  }

  /* ── Starting Lineups ──────────────────────────────────────────────────── */

  .lineup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .lineup-col-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.875rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .lineup-col-header-a {
    border-right: 1px solid var(--color-border);
  }

  .lineup-col-header-b {
    justify-content: flex-end;
  }

  .lineup-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    background: var(--slot-surface);
    border-bottom: 1px solid var(--slot-glow);
  }

  .lineup-row-a {
    border-right: 1px solid var(--color-border);
  }

  .lineup-row-b {
    flex-direction: row-reverse;
  }

  .lineup-pos {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--slot-glow);
    border: 1px solid var(--slot-glow);
    padding: 0.15rem 0.3rem;
    border-radius: 2px;
    flex-shrink: 0;
    min-width: 2.6rem;
    text-align: center;
  }

  .lineup-thumb {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lineup-thumb img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .lineup-name {
    flex: 1;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-primary);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lineup-row-b .lineup-name {
    text-align: right;
  }

  .lineup-score {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-primary);
    flex-shrink: 0;
    min-width: 2.75rem;
    text-align: right;
  }

  .lineup-row-b .lineup-score {
    text-align: left;
  }

  /* ── Recap ──────────────────────────────────────────────────────────────── */

  .recap-body :global(p) {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }

  .recap-body :global(h2),
  .recap-body :global(h3) {
    font-family: var(--font-display);
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
  }

  /* ── Mobile: Team A above Team B ──────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Single column — items flow in DOM order by default (order: 0) */
    .lineup-grid {
      grid-template-columns: 1fr;
    }

    /* Remove Team A's right border (no adjacent column) */
    .lineup-col-header-a {
      border-right: none;
    }

    .lineup-row-a {
      border-right: none;
    }

    /* Team B header: push below all Team A rows, match Team A's LTR layout */
    .lineup-col-header-b {
      order: 50;
      flex-direction: row-reverse; /* DOM: [name][img] → displays: [img][name] */
      justify-content: flex-start;
      border-top: 1px solid var(--color-border);
    }

    /* Team B rows: push below Team B header, restore LTR order */
    .lineup-row-b {
      order: 51;
      flex-direction: row;
    }

    /* Reset Team B text alignments to match Team A */
    .lineup-row-b .lineup-name {
      text-align: left;
    }

    .lineup-row-b .lineup-score {
      text-align: right;
    }
  }
</style>
