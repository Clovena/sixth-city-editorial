---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import franchisesJson from '../../../data/franchises.json';
import { mapStartersToSlots, mapExhibitionStartersToSlots } from '../../../lib/lineup';
import playerIdMap from '../../../data/player-id-map.json';

// ── Static paths — self-contained, no module-scope variable access ────────────
export async function getStaticPaths() {
  const { default: franchises } = await import('../../../data/franchises.json');
  const franchiseById = Object.fromEntries(franchises.map((f: any) => [f.id, f]));

  const matchupGlob = import.meta.glob('/src/data/raw/*-matchups.json', { eager: true });
  const paths: any[] = [];

  for (const [path, mod] of Object.entries(matchupGlob)) {
    const m = path.match(/(\d{4})-matchups/);
    if (!m) continue;
    const yearStr = m[1];
    const weeks = (mod as { default: Record<string, any[]> }).default;

    for (const [weekStr, entries] of Object.entries(weeks)) {
      const grouped: Record<number, any[]> = {};
      for (const e of entries) {
        if (!e.matchup_id) continue;
        if (!grouped[e.matchup_id]) grouped[e.matchup_id] = [];
        grouped[e.matchup_id].push(e);
      }

      for (const pair of Object.values(grouped)) {
        if (pair.length < 2) continue;
        const [eA, eB] = pair;
        const fA = franchiseById[eA.roster_id];
        const fB = franchiseById[eB.roster_id];
        if (!fA || !fB) continue;

        const weekNum = parseInt(weekStr);
        const weekPad = String(weekNum).padStart(2, '0');

        // Use predecessor abbreviations if franchise was adopted before this year
        const getEffectiveAbbr = (franchise: any, yr: number) => {
          if (franchise.founded !== 2021 && yr < franchise.founded) {
            return franchise.predecessor_abbr;
          }
          return franchise.abbr;
        };

        const abbr1 = getEffectiveAbbr(fA, parseInt(yearStr));
        const abbr2 = getEffectiveAbbr(fB, parseInt(yearStr));
        const [t1, t2] = [abbr1.toLowerCase(), abbr2.toLowerCase()].sort();
        const slug = `${weekPad}-${t1}-${t2}`;

        paths.push({
          params: { year: yearStr, slug },
          props: { year: parseInt(yearStr), week: weekNum, rosterIdA: eA.roster_id, rosterIdB: eB.roster_id },
        });
      }
    }
  }

  // ── Exhibition paths ──────────────────────────────────────────────────────
  const { default: exhibitionsData } = await import('../../../data/raw/exhibitions.json');
  for (const exhib of exhibitionsData) {
    paths.push({
      params: { year: String(exhib.year), slug: exhib.slug },
      props: { year: exhib.year, week: exhib.week, isExhibition: true, exhib },
    });
  }

  return paths;
}

// ── Page component ────────────────────────────────────────────────────────────
const { year, week, isExhibition, exhib, rosterIdA, rosterIdB } = Astro.props;
const { slug } = Astro.params;

// Load matchup data for this page
const matchupGlob = import.meta.glob('/src/data/raw/*-matchups.json', { eager: true });
const matchupsData: Record<string, Record<string, any[]>> = {};
for (const [path, mod] of Object.entries(matchupGlob)) {
  const m = path.match(/(\d{4})-matchups/);
  if (!m) continue;
  matchupsData[m[1]] = (mod as { default: Record<string, any[]> }).default;
}

let fA: any, fB: any, effA: any, effB: any, scoreA: number, scoreB: number, aWins: boolean, bWins: boolean;
let winsA = 0, lossesA = 0, winsB = 0, lossesB = 0;
let lineupA: any[], lineupB: any[];
let pageTitle: string;

if (isExhibition && exhib) {
  // Exhibition game
  scoreA = exhib.team_a.score;
  scoreB = exhib.team_b.score;
  aWins = scoreA > scoreB;
  bWins = scoreB > scoreA;

  lineupA = mapExhibitionStartersToSlots(exhib.team_a.starters, exhib.team_a.starters_points, exhib.exhib_type);
  lineupB = mapExhibitionStartersToSlots(exhib.team_b.starters, exhib.team_b.starters_points, exhib.exhib_type);

  effA = { name: exhib.team_a.display_name, logoAbbr: exhib.team_a.members[0] ?? 'UNKNOWN', members: exhib.team_a.members };
  effB = { name: exhib.team_b.display_name, logoAbbr: exhib.team_b.members[0] ?? 'UNKNOWN', members: exhib.team_b.members };

  pageTitle = `${effA.name} vs ${effB.name}`;
} else {
  // Regular game
  const franchiseById = Object.fromEntries(franchisesJson.map(f => [f.id, f]));
  fA = franchiseById[rosterIdA]!;
  fB = franchiseById[rosterIdB]!;

  // Scores
  const weekEntries: any[] = matchupsData[String(year)]?.[String(week)] ?? [];
  const regularEntryA = weekEntries.find((e: any) => e.roster_id === rosterIdA);
  const regularEntryB = weekEntries.find((e: any) => e.roster_id === rosterIdB);
  scoreA = regularEntryA ? (regularEntryA.custom_points != null ? regularEntryA.custom_points : regularEntryA.points) : 0;
  scoreB = regularEntryB ? (regularEntryB.custom_points != null ? regularEntryB.custom_points : regularEntryB.points) : 0;
  aWins = scoreA > scoreB;
  bWins = scoreB > scoreA;

  // Records through this week
  const allWeeks = matchupsData[String(year)] ?? {};
  const sortedWeekNums = Object.keys(allWeeks).map(Number).sort((a, b) => a - b);
  for (const w of sortedWeekNums) {
    if (w > week) break;
    const wEntries: any[] = allWeeks[String(w)] ?? [];
    const gGrouped: Record<number, any[]> = {};
    for (const e of wEntries) {
      if (!e.matchup_id) continue;
      if (!gGrouped[e.matchup_id]) gGrouped[e.matchup_id] = [];
      gGrouped[e.matchup_id].push(e);
    }
    for (const gPair of Object.values(gGrouped)) {
      if (gPair.length < 2) continue;
      const myA = gPair.find((e: any) => e.roster_id === rosterIdA);
      if (myA) {
        const opp = gPair.find((e: any) => e.roster_id !== rosterIdA)!;
        const myS = myA.custom_points != null ? myA.custom_points : myA.points;
        const oppS = opp.custom_points != null ? opp.custom_points : opp.points;
        if (myS > oppS) winsA++; else if (oppS > myS) lossesA++;
      }
      const myB = gPair.find((e: any) => e.roster_id === rosterIdB);
      if (myB) {
        const opp = gPair.find((e: any) => e.roster_id !== rosterIdB)!;
        const myS = myB.custom_points != null ? myB.custom_points : myB.points;
        const oppS = opp.custom_points != null ? opp.custom_points : opp.points;
        if (myS > oppS) winsB++; else if (oppS > myS) lossesB++;
      }
    }
  }

  // Effective identity (adopted franchises use predecessor identity pre-founding)
  function getEffective(franchise: any, yr: number) {
    if (franchise.founded !== 2021 && yr < franchise.founded) {
      const rebrand = franchise.rebrands?.find((r: any) => r.year === yr);
      return {
        name: rebrand?.name ?? franchise.name,
        logoAbbr: franchise.predecessor_abbr ?? franchise.abbr,
      };
    }
    return { name: franchise.name, logoAbbr: franchise.abbr };
  }
  effA = getEffective(fA, year);
  effB = getEffective(fB, year);

  // Lineups
  lineupA = mapStartersToSlots(regularEntryA?.starters ?? [], regularEntryA?.starters_points ?? [], year, week);
  lineupB = mapStartersToSlots(regularEntryB?.starters ?? [], regularEntryB?.starters_points ?? [], year, week);

  pageTitle = `${effA.name} vs ${effB.name}`;
}

// Recap (same for both regular and exhibition)
const allRecaps = await getCollection('recaps');
const recap = allRecaps.find(r => r.id === `${year}/${slug}`) ?? null;
let Content: any = null;
if (recap) {
  const rendered = await render(recap);
  Content = rendered.Content;
  pageTitle = recap.data.title;
}

// Player metadata helpers
const pMap = playerIdMap as Record<string, { espn_id?: string; full_name: string; position: string }>;
function playerName(id: string) { return pMap[id]?.full_name || id; }
function espnHeadshotUrl(id: string) { const espnId = pMap[id]?.espn_id; return espnId ? `https://a.espncdn.com/i/headshots/nfl/players/full/${espnId}.png` : null; }
---

<Layout title={pageTitle} description={`Week ${week}, ${year} — ${effA.name} vs ${effB.name}`}>

  <div style="max-width: 760px; margin: 0 auto; padding: 4rem 1.5rem 6rem;">

    <a href="/scores" style="font-family: var(--font-body); font-size: 0.72rem; font-weight: 600; color: var(--color-text-muted); text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;">← Scores</a>

    {isExhibition ? (
      <p class="section-label" style="margin-top: 1.75rem;">Exhibition &middot; Week {week} &middot; {year}</p>
    ) : (
      <p class="section-label" style="margin-top: 1.75rem;">Week {week} &middot; {year} Season</p>
    )}

    <!-- Score block -->
    <div style="border: 1px solid var(--color-border); border-radius: 8px; overflow: hidden; margin-top: 0.75rem;">

      <div class:list={['game-team', aWins ? 'winner' : bWins ? 'loser' : 'tied']}>
        {isExhibition && effA.members ? (
          <div style="display: flex; gap: 4px; flex-shrink: 0;">
            {effA.members.map((abbr: string) => (
              <img src={`/images/logos/${abbr}.png`} alt={abbr} width="36" height="36"
                   style="object-fit: contain;" onerror="this.style.display='none'" />
            ))}
          </div>
        ) : (
          <img src={`/images/logos/${effA.logoAbbr}.png`} alt={effA.name} width="52" height="52"
               style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
        )}
        <div style="flex: 1; min-width: 0;">
          <div class="game-team-name">{effA.name}</div>
          {!isExhibition && <div class="game-record">{winsA}–{lossesA}</div>}
        </div>
        <span class:list={['game-score', aWins ? 'winner' : '']}>{scoreA.toFixed(2)}</span>
      </div>

      <div style="height: 1px; background: var(--color-border);"></div>

      <div class:list={['game-team', bWins ? 'winner' : aWins ? 'loser' : 'tied']}>
        {isExhibition && effB.members ? (
          <div style="display: flex; gap: 4px; flex-shrink: 0;">
            {effB.members.map((abbr: string) => (
              <img src={`/images/logos/${abbr}.png`} alt={abbr} width="36" height="36"
                   style="object-fit: contain;" onerror="this.style.display='none'" />
            ))}
          </div>
        ) : (
          <img src={`/images/logos/${effB.logoAbbr}.png`} alt={effB.name} width="52" height="52"
               style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
        )}
        <div style="flex: 1; min-width: 0;">
          <div class="game-team-name">{effB.name}</div>
          {!isExhibition && <div class="game-record">{winsB}–{lossesB}</div>}
        </div>
        <span class:list={['game-score', bWins ? 'winner' : '']}>{scoreB.toFixed(2)}</span>
      </div>

    </div>

    <!-- Starting Lineups -->
    <div style="margin-top: 2rem;">
      <p class="section-label">Starting Lineups</p>
      <div class="lineup-grid">

        <!-- Column headers -->
        <div class="lineup-col-header lineup-col-header-a">
          {isExhibition && effA.members ? (
            <div style="display: flex; gap: 2px;">
              {effA.members.map((abbr: string) => (
                <img src={`/images/logos/${abbr}.png`} alt={abbr} width="18" height="18"
                     style="object-fit: contain;" onerror="this.style.display='none'" />
              ))}
            </div>
          ) : (
            <img src={`/images/logos/${effA.logoAbbr}.png`} alt="" width="22" height="22"
                 style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
          )}
          <span>{effA.name}</span>
        </div>
        <div class="lineup-col-header lineup-col-header-b">
          <span>{effB.name}</span>
          {isExhibition && effB.members ? (
            <div style="display: flex; gap: 2px;">
              {effB.members.map((abbr: string) => (
                <img src={`/images/logos/${abbr}.png`} alt={abbr} width="18" height="18"
                     style="object-fit: contain;" onerror="this.style.display='none'" />
              ))}
            </div>
          ) : (
            <img src={`/images/logos/${effB.logoAbbr}.png`} alt="" width="22" height="22"
                 style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
          )}
        </div>

        <!-- Roster rows -->
        {lineupA.map((slotA, i) => {
          const slotB = lineupB[i];
          if (!slotA.visible) return null;
          return (
            <>
              <div
                class="lineup-row lineup-row-a"
                style={`--slot-surface: var(--color-${slotA.colorVar}-surface); --slot-glow: var(--color-${slotA.colorVar}-glow);`}
              >
                <span class="lineup-pos">{slotA.position}</span>
                <span class="lineup-thumb">
                  {espnHeadshotUrl(slotA.playerId)
                    ? <img src={espnHeadshotUrl(slotA.playerId)!} alt={playerName(slotA.playerId)} width="28" height="28" loading="lazy" decoding="async" onerror="this.src='/images/player-placeholder.png';this.onerror=null;" />
                    : null}
                </span>
                <span class="lineup-name">{playerName(slotA.playerId)}</span>
                <span class="lineup-score">{slotA.points.toFixed(2)}</span>
              </div>
              <div
                class="lineup-row lineup-row-b"
                style={`--slot-surface: var(--color-${slotB.colorVar}-surface); --slot-glow: var(--color-${slotB.colorVar}-glow);`}
              >
                <span class="lineup-pos">{slotB.position}</span>
                <span class="lineup-thumb">
                  {espnHeadshotUrl(slotB.playerId)
                    ? <img src={espnHeadshotUrl(slotB.playerId)!} alt={playerName(slotB.playerId)} width="28" height="28" loading="lazy" decoding="async" onerror="this.src='/images/player-placeholder.png';this.onerror=null;" />
                    : null}
                </span>
                <span class="lineup-name">{playerName(slotB.playerId)}</span>
                <span class="lineup-score">{slotB.points.toFixed(2)}</span>
              </div>
            </>
          );
        })}

      </div>
    </div>

    <!-- Recap (only rendered when a file exists) -->
    {recap && (
      <div style="margin-top: 3.5rem;">
        <h1 class="page-title" style="margin: 0;">{recap.data.title}</h1>
        {recap.data.subtitle && (
          <p style="font-family: var(--font-body); font-size: 1.05rem; color: var(--color-text-muted); margin: 0.6rem 0 0; line-height: 1.5;">{recap.data.subtitle}</p>
        )}
        <p style="font-family: var(--font-body); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); margin: 1rem 0 0;">
          {recap.data.date}
        </p>
        <hr style="border: none; border-top: 1px solid var(--color-border); margin: 1.5rem 0;" />
        <div class="recap-body" style="text-align: justify;">
          {Content && <Content />}
        </div>
      </div>
    )}

  </div>

</Layout>

<style>
  .game-team {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .game-team.winner {
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .game-team.loser {
    opacity: 0.55;
  }

  .game-team-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .game-record {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
  }

  .game-score {
    font-family: var(--font-body);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-muted);
    flex-shrink: 0;
    min-width: 4.5rem;
    text-align: right;
  }

  .game-score.winner {
    color: var(--color-gold);
  }

  /* ── Starting Lineups ──────────────────────────────────────────────────── */

  .lineup-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .lineup-col-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.875rem;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .lineup-col-header-a {
    border-right: 1px solid var(--color-border);
  }

  .lineup-col-header-b {
    justify-content: flex-end;
  }

  .lineup-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    background: var(--slot-surface);
    border-bottom: 1px solid var(--slot-glow);
  }

  .lineup-row-a {
    border-right: 1px solid var(--color-border);
  }

  .lineup-row-b {
    flex-direction: row-reverse;
  }

  .lineup-pos {
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--slot-glow);
    border: 1px solid var(--slot-glow);
    padding: 0.15rem 0.3rem;
    border-radius: 2px;
    flex-shrink: 0;
    min-width: 2.6rem;
    text-align: center;
  }

  .lineup-thumb {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lineup-thumb img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .lineup-name {
    flex: 1;
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: var(--color-text-primary);
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lineup-row-b .lineup-name {
    text-align: right;
  }

  .lineup-score {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text-primary);
    flex-shrink: 0;
    min-width: 2.75rem;
    text-align: right;
  }

  .lineup-row-b .lineup-score {
    text-align: left;
  }

  /* ── Recap ──────────────────────────────────────────────────────────────── */

  .recap-body :global(p) {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--color-text-primary);
    margin: 0 0 1.25rem;
  }

  .recap-body :global(h2),
  .recap-body :global(h3) {
    font-family: var(--font-display);
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
  }

  /* ── Mobile: Team A above Team B ──────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Single column — items flow in DOM order by default (order: 0) */
    .lineup-grid {
      grid-template-columns: 1fr;
    }

    /* Remove Team A's right border (no adjacent column) */
    .lineup-col-header-a {
      border-right: none;
    }

    .lineup-row-a {
      border-right: none;
    }

    /* Team B header: push below all Team A rows, match Team A's LTR layout */
    .lineup-col-header-b {
      order: 50;
      flex-direction: row-reverse; /* DOM: [name][img] → displays: [img][name] */
      justify-content: flex-start;
      border-top: 1px solid var(--color-border);
    }

    /* Team B rows: push below Team B header, restore LTR order */
    .lineup-row-b {
      order: 51;
      flex-direction: row;
    }

    /* Reset Team B text alignments to match Team A */
    .lineup-row-b .lineup-name {
      text-align: left;
    }

    .lineup-row-b .lineup-score {
      text-align: right;
    }
  }
</style>
