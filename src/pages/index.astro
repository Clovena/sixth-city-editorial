---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

// ── Fetch all franchise identities (including historical) ─────────────────
const { data: allFranchises, error: fErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('id, sleeper_id, abbr, name, owner, conf, colors, "from", "to"');

if (fErr || !allFranchises) throw new Error(`Franchises query failed: ${fErr?.message || 'No data returned'}`);

const activeFranchises = allFranchises.filter(f => f.to === null);
const activeBySleeperId = new Map(activeFranchises.map(f => [f.sleeper_id, f]));

function franchiseForYear(sleeperId: string, yr: number) {
  return activeFranchises.find(f =>
    f.sleeper_id === sleeperId && f.from <= yr && (f.to === null || f.to >= yr)
  );
}

// ── Fetch championship matchups (week 17, game_type = 1) ──────────────────
const { data: champMatchups, error: cmErr } = await supabase
  .schema('scdfl')
  .from('matchups')
  .select('year, roster_id_a, roster_id_b, score_a, score_b')
  .eq('week', 17)
  .eq('game_type', 1)
  .order('year', { ascending: false });

if (cmErr) throw new Error(`Championship matchups query failed: ${cmErr.message}`);

// ── Roman numeral helper ──────────────────────────────────────────────────
function toRoman(n: number): string {
  const vals = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const syms = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let result = '';
  for (let i = 0; i < vals.length; i++) {
    while (n >= vals[i]) { result += syms[i]; n -= vals[i]; }
  }
  return result;
}

// ── Build recent dynasty bowls (last 3) ───────────────────────────────────
type BowlDisplay = {
  year: number;
  label: string;
  winner: typeof allFranchises[0] | undefined;
  loser: typeof allFranchises[0] | undefined;
};

const recentBowls: BowlDisplay[] = [];
for (const m of champMatchups.slice(0, 3)) {
  const aWins = m.score_a > m.score_b;
  const winnerSleeperId = String(aWins ? m.roster_id_a : m.roster_id_b);
  const loserSleeperId = String(aWins ? m.roster_id_b : m.roster_id_a);
  recentBowls.push({
    year: m.year,
    label: `Dynasty Bowl ${toRoman(m.year - 2020)}`,
    winner: franchiseForYear(winnerSleeperId, m.year),
    loser: franchiseForYear(loserSleeperId, m.year),
  });
}

// ── Unique champions (attributed to current identity) ─────────────────────
const champSet = new Set<string>();
for (const m of champMatchups) {
  const aWins = m.score_a > m.score_b;
  const winnerSleeperId = String(aWins ? m.roster_id_a : m.roster_id_b);
  const active = activeBySleeperId.get(winnerSleeperId);
  if (active) champSet.add(active.abbr);
}
const totalChampions = champSet.size;

// Total completed dynasty bowls
const totalBowls = champMatchups.length;

---

<Layout title="SCDFL" description="Sixth City Dynasty Fantasy Football League. 14 franchises, 5 seasons, 4 champions. Est. 2021.">

  <!-- Hero -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
    <div style="padding: 5rem 0 4rem; border-bottom: 1px solid var(--color-border);">

      <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 7vw, 5rem); font-weight: 700; line-height: 1.05; letter-spacing: -0.02em; color: var(--color-text-primary); margin: 0 0 1.5rem; max-width: 14ch;">
        Sixth City Dynasty Football League
      </h1>

      <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-gold-dim); margin-bottom: 1.25rem;">Est. 2021 &bull; Cleveland, Ohio</p>

      <p class="page-subtitle" style="font-size: 1.05rem; color: var(--color-text-secondary); line-height: 1.65; max-width: 58ch; margin: 0 0 2.5rem;">
        The Sixth City Dynasty Football League was founded in 2021 as a
        branch off of a standard redraft league with origins in the Sigma
        Phi Epsilon Ohio Zeta chapter. Rooted in Cleveland, Sixth City is
        host to members throughout the state of Ohio.
      </p>

      <!-- Quick stats row -->
      <div class="quick-stats-grid" style="display: flex; flex-wrap: wrap; gap: 0; border: 1px solid var(--color-border); width: fit-content;">
        {[
          { label: 'Franchises', value: '14' },
          { label: 'Seasons Completed', value: '5' },
          { label: 'Champions', value: String(totalChampions) },
          { label: 'Dynasty Bowls', value: String(totalBowls) },
        ].map((stat, i) => (
          <div style={`padding: 1.1rem 1.75rem; ${i !== 0 ? 'border-left: 1px solid var(--color-border);' : ''} background-color: var(--color-surface);`}>
            <p style="font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--color-text-primary); line-height: 1; margin: 0;">{stat.value}</p>
            <p style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted); margin: 0.3rem 0 0;">{stat.label}</p>
          </div>
        ))}
      </div>

      <!-- Season status -->
      <div style="margin-top: 2rem; display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.6rem 1rem; background-color: var(--color-surface); border: 1px solid var(--color-border);">
        <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background-color: var(--color-gold); opacity: 0.6;"></span>
        <span style="font-size: 0.8rem; font-weight: 600; color: var(--color-text-secondary); letter-spacing: 0.04em;">Season 6 begins September 9th, 2026</span>
      </div>
      
      <!-- Primary section nav -->
      <div class="section-nav-grid" style="margin-top: 2rem; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background-color: var(--color-border); margin-bottom: 0;">

        <a href="/scores" style="text-decoration: none; display: block; background-color: var(--color-surface); padding: 2rem; transition: background-color 0.15s ease;" onmouseover="this.style.backgroundColor='var(--color-surface-alt)'" onmouseout="this.style.backgroundColor='var(--color-surface)'">
          <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.25;">Scoreboard</h3>
          <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5; margin: 0 0 1rem;">Scores and recaps of every game across the season. Check on this week's matchups, revisit historical showdowns, and explore the way history was made.</p>
          <span style="font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold);">View Scores &#8594;</span>
        </a>

        <a href="/content" style="text-decoration: none; display: block; background-color: var(--color-surface); padding: 2rem; transition: background-color 0.15s ease;" onmouseover="this.style.backgroundColor='var(--color-surface-alt)'" onmouseout="this.style.backgroundColor='var(--color-surface)'">
          <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.25;">Content</h3>
          <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5; margin: 0 0 1rem;">Power Rankings, mock drafts, schedule previews, and more. Written by the commissioner and other league members.</p>
          <span style="font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold);">View Content &#8594;</span>
        </a>
      </div>
    </div>
  </div>


  <!-- Recent Dynasty Bowls -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
    <div style="margin-top: 4rem;">
      <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 0.75rem;">
        <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin: 0; color: var(--color-text-primary);">Recent Dynasty Bowls</h2>
        <a href="/history" style="font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold-dim);">Full History &#8594;</a>
      </div>

      <div style="display: flex; flex-direction: column; gap: 1px; background-color: var(--color-border);">
        {recentBowls.map(bowl => {
          const winner = bowl.winner;
          const loser = bowl.loser;
          return (
            <div class="dynasty-bowl-row" style="background-color: var(--color-surface); padding: 1.5rem 1.75rem; display: grid; grid-template-columns: 80px 1fr 1fr; gap: 2rem; align-items: center;">

              <div>
                <p style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; color: var(--color-gold); line-height: 1; margin: 0;">{bowl.year}</p>
                <p style="font-size: 0.7rem; color: var(--color-text-muted); margin: 0.2rem 0 0;">{bowl.label}</p>
              </div>

              <div style={`border-left: 3px solid ${winner?.colors[0]}; padding-left: 1.25rem; display: flex; align-items: center; gap: 0.9rem;`}>
                <img
                  src={`/images/logos/${winner?.abbr}.png`}
                  alt=""
                  width="32"
                  height="32"
                  style="object-fit: contain; flex-shrink: 0;"
                  onerror="this.style.display='none'"
                />
                <div>
                  <p style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-gold-dim); margin: 0 0 0.2rem;">Champion</p>
                  <a href={`/franchises/${winner?.abbr}`} style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--color-gold); text-decoration: none; line-height: 1.2; display: block;">
                    {winner?.name}
                  </a>
                  <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0.2rem 0 0;">{winner?.abbr} &bull; {winner?.owner}</p>
                </div>
              </div>

              <div class="dynasty-bowl-loser" style="padding-left: 1.25rem; display: flex; align-items: center; gap: 0.9rem;">
                <img
                  src={`/images/logos/${loser?.abbr}.png`}
                  alt=""
                  width="32"
                  height="32"
                  style="object-fit: contain; flex-shrink: 0; opacity: 0.6;"
                  onerror="this.style.display='none'"
                />
                <div>
                  <p style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.2rem;">Runner-Up</p>
                  <a href={`/franchises/${loser?.abbr}`} style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--color-text-secondary); text-decoration: none; line-height: 1.2; display: block;">
                    {loser?.name}
                  </a>
                  <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0.2rem 0 0;">{loser?.abbr} &bull; {loser?.owner}</p>
                </div>
              </div>

            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Secondary section nav -->
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">
    <div class="section-nav-grid" style="margin-top: 4rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background-color: var(--color-border); margin-bottom: 0;">

      <a href="/history" style="text-decoration: none; display: block; background-color: var(--color-surface); padding: 2rem; transition: background-color 0.15s ease;" onmouseover="this.style.backgroundColor='var(--color-surface-alt)'" onmouseout="this.style.backgroundColor='var(--color-surface)'">
        <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.25;">History &amp; Records</h3>
        <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5; margin: 0 0 1rem;">Season results, the championship roll of honor, narrative recaps, and the full statistical record.</p>
        <span style="font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold);">View History &#8594;</span>
      </a>

      <a href="/franchises" style="text-decoration: none; display: block; background-color: var(--color-surface); padding: 2rem; transition: background-color 0.15s ease;" onmouseover="this.style.backgroundColor='var(--color-surface-alt)'" onmouseout="this.style.backgroundColor='var(--color-surface)'">
        <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.25;">Franchises</h3>
        <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5; margin: 0 0 1rem;">All 14 franchises across the SCC and HCC. Ownership, history, colors, and individual franchise records.</p>
        <span style="font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold);">View Franchises &#8594;</span>
      </a>

      <a href="/spotlight-games" style="text-decoration: none; display: block; background-color: var(--color-surface); padding: 2rem; transition: background-color 0.15s ease;" onmouseover="this.style.backgroundColor='var(--color-surface-alt)'" onmouseout="this.style.backgroundColor='var(--color-surface)'">
        <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.25;">Spotlight Games</h3>
        <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5; margin: 0 0 1rem;">The 2026 bowl game slate, Rivalry Week, and the institutional pairings that define the regular season.</p>
        <span style="font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-gold);">View Spotlight Games &#8594;</span>
      </a>
    </div>
  </div>
</Layout>

<style>
  @media (max-width: 768px) {
    /* Quick stats: 2×2 grid filling full width */
    .quick-stats-grid {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      width: 100% !important;
    }

    /* Reset all left borders, then restore for right-column cells */
    .quick-stats-grid > div {
      border-left: none !important;
    }

    .quick-stats-grid > div:nth-child(even) {
      border-left: 1px solid var(--color-border) !important;
    }

    .quick-stats-grid > div:nth-child(3),
    .quick-stats-grid > div:nth-child(4) {
      border-top: 1px solid var(--color-border);
    }

    /* Dynasty bowls: hide runner-up, collapse to 2 columns */
    .dynasty-bowl-loser {
      display: none !important;
    }

    .dynasty-bowl-row {
      grid-template-columns: 80px 1fr !important;
    }

    /* Section nav: stack vertically */
    .section-nav-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
