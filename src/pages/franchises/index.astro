---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

// ── Fetch active franchises ───────────────────────────────────────────────
const { data: activeFranchises, error: fErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('sleeper_id, abbr, name, owner, conf, colors')
  .is('to', null)
  .order('abbr');

if (fErr || !activeFranchises) throw new Error(`Franchises query failed: ${fErr?.message || 'No data returned'}`);

// ── Fetch all franchise identities (for historical abbr → sleeper_id mapping) ─
const { data: allIdentities, error: aiErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('sleeper_id, abbr, "from", "to"');

if (aiErr) throw new Error(`All identities query failed: ${aiErr.message}`);

// Map: abbr → sleeper_id (covers historical abbrs too)
const sleeperIdByAbbr = new Map(allIdentities.map(f => [f.abbr, f.sleeper_id]));

// ── Fetch seasons (for conf champion attribution) ─────────────────────────
const { data: seasonRows, error: sErr } = await supabase
  .schema('scdfl')
  .from('seasons')
  .select('year, scc_champion, hcc_champion');

if (sErr) throw new Error(`Seasons query failed: ${sErr.message}`);

// ── Fetch championship matchups (week 17, game_type = 1) ──────────────────
const { data: champMatchups, error: cmErr } = await supabase
  .schema('scdfl')
  .from('matchups')
  .select('year, roster_id_a, roster_id_b, score_a, score_b')
  .eq('week', 17)
  .eq('game_type', 1);

if (cmErr) throw new Error(`Championship matchups query failed: ${cmErr.message}`);

// ── Build accolade counts (attributed to active franchise via sleeper_id) ─
const activeBySleeperId = new Map(activeFranchises.map(f => [f.sleeper_id, f]));

const champCounts: Record<string, number> = {};
const runnerUpCounts: Record<string, number> = {};
const confTitleCounts: Record<string, number> = {};

// Championships & runner-ups from matchup results
for (const m of champMatchups ?? []) {
  const aWins = m.score_a > m.score_b;
  const winnerSleeperId = String(aWins ? m.roster_id_a : m.roster_id_b);
  const loserSleeperId = String(aWins ? m.roster_id_b : m.roster_id_a);
  const winner = activeBySleeperId.get(winnerSleeperId);
  const loser = activeBySleeperId.get(loserSleeperId);
  if (winner) champCounts[winner.abbr] = (champCounts[winner.abbr] || 0) + 1;
  if (loser) runnerUpCounts[loser.abbr] = (runnerUpCounts[loser.abbr] || 0) + 1;
}

// Conference titles from seasons
for (const s of seasonRows ?? []) {
  for (const confAbbr of [s.scc_champion, s.hcc_champion]) {
    if (!confAbbr) continue;
    const sleeperId = sleeperIdByAbbr.get(confAbbr);
    if (!sleeperId) continue;
    const active = activeBySleeperId.get(sleeperId);
    if (active) confTitleCounts[active.abbr] = (confTitleCounts[active.abbr] || 0) + 1;
  }
}

const sccFranchises = activeFranchises.filter(f => f.conf === 'SCC');
const hccFranchises = activeFranchises.filter(f => f.conf === 'HCC');
---

<Layout title="Franchises" description="All 14 franchises of the Sixth City Dynasty Football League.">

  <div style="max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 0;">

    <!-- Page header -->
    <div style="padding-bottom: 2.5rem; border-bottom: 1px solid var(--color-border);">
      <p class="section-label">League Membership</p>
      <h1 class="page-title">Franchises</h1>
      <p class="page-subtitle" style="margin-top: 0.75rem;">
        Fourteen franchises across two conferences comprise Sixth City 
        Dynasty. Many organizations are based in Canada, but the league 
        stretches down to the US and across the globe to Australia.
      </p>
    </div>

    <!-- SCC -->
    <div style="margin-top: 3rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <h2 style="font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; margin: 0; color: var(--color-text-primary);">Senatorial Canadian Conference</h2>
        <span class="label-badge badge-scc">SCC</span>
      </div>
      <div>
        <p class="page-subtitle" style="margin: 0.75rem 0 1.5rem;">
          The SCC embraces the everyman’s approach to football: hard-nosed,
          down and dirty blue collar football that the people love. However, 
          some wonder whether or not they are willing to adapt to the way
          the game is changing.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background-color: var(--color-border);">
        {sccFranchises.map(franchise => {
          const primaryColor = franchise.colors[0];
          return (
            <a href={`/franchises/${franchise.abbr}`} style="text-decoration: none; display: block;">
              <div class="franchise-card" style={`border-left: 3px solid ${primaryColor};`}>
                <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.75rem;">
                  <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <img
                      src={`/images/logos/${franchise.abbr}.png`}
                      alt=""
                      width="36"
                      height="36"
                      style="object-fit: contain; flex-shrink: 0;"
                      onerror="this.style.display='none'"
                    />
                    <div>
                      <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.3rem;">{franchise.abbr}</p>
                      <h3 style="font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--color-text-primary); margin: 0; line-height: 1.2;">{franchise.name}</h3>
                      <p style="font-size: 0.8rem; color: var(--color-text-muted); font-style: italic; margin: 0;">{franchise.owner}</p>
                    </div>
                  </div>
                  <div style="display: flex; flex-direction: column;">
                    <div style="display: inline-flex; align-items: center; gap: 10px; justify-content: flex-end; margin: 0.75rem 0.25rem;">
                      {franchise.colors.map(color => (
                        <span style={`display: inline-flex; width: 0.75rem; height: 0.75rem; background-color: ${color}; border-radius: 50%; line-height: 1;`}></span>
                      ))}
                    </div>
                    {(() => {
                      const champs = champCounts[franchise.abbr] || 0;
                      const runnerUps = runnerUpCounts[franchise.abbr] || 0;
                      const confTitles = confTitleCounts[franchise.abbr] || 0;
                      const confColor = franchise.conf === 'SCC' ? 'var(--color-scc)' : 'var(--color-hcc)';
                      if (champs + runnerUps + confTitles === 0) return null;
                      return (
                        <div style="display: flex; gap: 1px; flex-shrink: 0; justify-content: flex-end;">
                          {Array.from({ length: champs }).map(() => (
                            <span style="display: inline-flex; align-items: flex-end; justify-content: center; width: 1.3rem; height: 1.3rem; color: var(--color-gold); font-size: 1.13rem; line-height: 1.3;">&#11042;</span>
                          ))}
                          {Array.from({ length: runnerUps }).map(() => (
                            <span style="display: inline-flex; align-items: flex-end; justify-content: center; width: 1.3rem; height: 1.3rem; color: var(--color-text-primary); font-size: 1.13rem; line-height: 1.3;">&#11041;</span>
                          ))}
                          {Array.from({ length: confTitles }).map(() => (
                            <span style={`display: inline-flex; align-items: center; justify-content: center; width: 1.3rem; height: 1.3rem; color: ${confColor}; font-size: 0.9rem; line-height: 1;`}>&#9650;</span>
                          ))}
                        </div>
                      );
                    })()}
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- HCC -->
    <div style="margin-top: 3rem; margin-bottom: 5rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <h2 style="font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; margin: 0; color: var(--color-text-primary);">House of Commons Conference</h2>
        <span class="label-badge badge-hcc">HCC</span>
      </div>
      <div>
        <p class="page-subtitle" style="margin: 0.75rem 0 1.5rem;">
          The HCC is the older and more prestigious conference. They pride 
          themselves on their refined strategies, but opponents might say 
          that their lackadaisical temperament has made them no longer 
          representative of what their cities want in a football team.
        </p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background-color: var(--color-border);">
        {hccFranchises.map(franchise => {
          const champs = champCounts[franchise.abbr] || 0;
          const primaryColor = franchise.colors[0];
          return (
            <a href={`/franchises/${franchise.abbr}`} style="text-decoration: none; display: block;">
              <div class="franchise-card" style={`border-left: 3px solid ${primaryColor};`}>
                <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 0.75rem;">
                  <div style="display: flex; align-items: center; gap: 0.75rem;">
                    <img
                      src={`/images/logos/${franchise.abbr}.png`}
                      alt=""
                      width="36"
                      height="36"
                      style="object-fit: contain; flex-shrink: 0;"
                      onerror="this.style.display='none'"
                    />
                    <div>
                      <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.3rem;">{franchise.abbr}</p>
                      <h3 style="font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--color-text-primary); margin: 0; line-height: 1.2;">{franchise.name}</h3>
                      <p style="font-size: 0.8rem; color: var(--color-text-muted); font-style: italic; margin: 0;">{franchise.owner}</p>
                    </div>
                  </div>
                  <div style="display: flex; flex-direction: column;">
                    <div style="display: inline-flex; align-items: center; gap: 10px; justify-content: flex-end; margin: 0.75rem 0.25rem;">
                      {franchise.colors.map(color => (
                        <span style={`display: inline-flex; width: 0.75rem; height: 0.75rem; background-color: ${color}; border-radius: 50%; line-height: 1;`}></span>
                      ))}
                    </div>
                    {(() => {
                      const champs = champCounts[franchise.abbr] || 0;
                      const runnerUps = runnerUpCounts[franchise.abbr] || 0;
                      const confTitles = confTitleCounts[franchise.abbr] || 0;
                      const confColor = franchise.conf === 'SCC' ? 'var(--color-scc)' : 'var(--color-hcc)';
                      if (champs + runnerUps + confTitles === 0) return null;
                      return (
                        <div style="display: flex; gap: 1px; flex-shrink: 0; justify-content: flex-end;">
                          {Array.from({ length: champs }).map(() => (
                            <span style="display: inline-flex; align-items: flex-end; justify-content: center; width: 1.3rem; height: 1.3rem; color: var(--color-gold); font-size: 1.13rem; line-height: 1.3;">&#11042;</span>
                          ))}
                          {Array.from({ length: runnerUps }).map(() => (
                            <span style="display: inline-flex; align-items: flex-end; justify-content: center; width: 1.3rem; height: 1.3rem; color: var(--color-text-primary); font-size: 1.13rem; line-height: 1.3;">&#11041;</span>
                          ))}
                          {Array.from({ length: confTitles }).map(() => (
                            <span style={`display: inline-flex; align-items: center; justify-content: center; width: 1.3rem; height: 1.3rem; color: ${confColor}; font-size: 0.9rem; line-height: 1;`}>&#9650;</span>
                          ))}
                        </div>
                      );
                    })()}
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

  </div>
</Layout>
