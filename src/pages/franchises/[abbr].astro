---
import Layout from '../../layouts/Layout.astro';
import franchises from '../../data/franchises.json';
import seasons from '../../data/seasons.json';
import spotlightGames from '../../data/spotlight_games.json';
import allResults from '../../data/results.json';
import config from '../../data/config.json';
import { getEntry, render, getCollection } from 'astro:content';

export async function getStaticPaths() {
  return franchises.map(f => ({ params: { abbr: f.abbr } }));
}

const { abbr } = Astro.params;
const franchise = franchises.find(f => f.abbr === abbr);

if (!franchise) {
  return Astro.redirect('/franchises');
}

// Get franchise notes markdown from content collection
const notesEntry = await getEntry('franchises', abbr.toLowerCase());
let FranchiseContent: any = null;
if (notesEntry) {
  const { Content } = await render(notesEntry);
  FranchiseContent = Content;
}

// All abbreviations this franchise has ever operated under (current + predecessors)
const allAbbrs: string[] = [abbr, ...(('predecessor_abbr' in franchise && franchise.predecessor_abbr) ? [franchise.predecessor_abbr as string] : [])];

const dynastyBowlAppearances = seasons.filter(s =>
  allAbbrs.includes(s.dynasty_bowl.winner) || allAbbrs.includes(s.dynasty_bowl.loser)
);

const championships = dynastyBowlAppearances.filter(s =>
  allAbbrs.includes(s.dynasty_bowl.winner)
);

const runnerUps = dynastyBowlAppearances.filter(s =>
  allAbbrs.includes(s.dynasty_bowl.loser)
);

// Conference championship history
const confChamps = seasons.filter(s => {
  const conf = franchise.conference === 'SCC' ? s.scc_champion : s.hcc_champion;
  return allAbbrs.includes(conf);
});

const confColor = franchise.conference === 'SCC' ? 'var(--color-scc)' : 'var(--color-hcc)';

// Bowl game affiliations for this franchise
const myBowlGames = spotlightGames.filter(bg => bg.type === "bowl-game" && (bg.team_a === abbr || bg.team_b === abbr));
const myRivalryGames = spotlightGames.filter(rg => rg.type === "rivalry" && (rg.team_a === abbr || rg.team_b === abbr));

// Helper to get opponent abbr for bowl
function getBowlOpponent(bg: typeof spotlightGames[0]) {
  return bg.team_a === abbr ? bg.team_b : bg.team_a;
}
function getRivalryOpponent(rg: typeof spotlightGames[0]) {
  return rg.team_a === abbr ? rg.team_b : rg.team_a;
}
function getOpponentFranchise(oppAbbr: string) {
  return franchises.find(f => f.abbr === oppAbbr);
}

// Seasonal record from results.json
const franchiseResults: Array<{year: number; wins: number; losses: number; points_for: number; points_against: number; playoff: boolean; finish: string}> =
  (allResults as Record<string, any[]>)[abbr] ?? [];

// Adoption: founded != 2021 means a new owner took over this roster mid-league
const isAdopted = franchise.founded !== 2021;
const predecessorAbbr = ('predecessor_abbr' in franchise ? franchise.predecessor_abbr as string : null);

// Rebrand history: build timeline label for current season name
const hasRebrands = franchise.rebrands && franchise.rebrands.length > 0;
const primaryColor = franchise.colors[0];
const secondaryColor = franchise.colors[1] ?? franchise.colors[0];

// Season record totals
const totalWins = franchiseResults.reduce((sum, r) => sum + r.wins, 0);
const totalLosses = franchiseResults.reduce((sum, r) => sum + r.losses, 0);
const totalPF = franchiseResults.reduce((sum, r) => sum + r.points_for, 0);
const totalPA = franchiseResults.reduce((sum, r) => sum + r.points_against, 0);

// ── Load matchup data at build time ──────────────────────────────────────────
const matchupGlob = import.meta.glob('/src/data/raw/*-matchups.json', { eager: true });

type MatchupEntry = { roster_id: number; matchup_id: number; score: number };
const matchupsData: Record<string, Record<string, MatchupEntry[]>> = {};

for (const [path, mod] of Object.entries(matchupGlob)) {
  const m = path.match(/(\d{4})-matchups/);
  if (!m) continue;
  const year = m[1];
  const raw = (mod as { default: Record<string, any[]> }).default;
  const weeks: Record<string, MatchupEntry[]> = {};
  for (const [week, entries] of Object.entries(raw)) {
    weeks[week] = entries.map(e => ({
      roster_id: e.roster_id,
      matchup_id: e.matchup_id,
      score: e.custom_points != null ? e.custom_points : e.points,
    }));
  }
  matchupsData[year] = weeks;
}

// ── Recap slug array ─────────────────────────────────────────────────────────
const allRecaps = await getCollection('recaps');
const recapSlugsArr: string[] = allRecaps.map(r => r.id); // "year/slug" keys

// ── Franchise lookup map (same as /scores) ──────────────────────────────────
type FranchiseEntry = {
  name: string;
  abbr: string;
  founded: number;
  predecessorAbbr: string | null;
  rebrands: Array<{ year: number; name: string }>;
};
const franchiseMap: Record<number, FranchiseEntry> = {};
for (const f of franchises) {
  franchiseMap[f.id] = {
    name: f.name,
    abbr: f.abbr,
    founded: f.founded,
    predecessorAbbr: ('predecessor_abbr' in f ? (f as any).predecessor_abbr : null) ?? null,
    rebrands: (f.rebrands ?? []) as Array<{ year: number; name: string }>,
  };
}

// ── Dynasty Bowl lookup ──────────────────────────────────────────────────────
const dynastyBowls: Record<string, { winner: string; loser: string; label: string }> = {};
for (const s of seasons) {
  dynastyBowls[String(s.year)] = {
    winner: s.dynasty_bowl.winner,
    loser: s.dynasty_bowl.loser,
    label: s.dynasty_bowl.label,
  };
}

// ── Determine available seasons for this franchise ──────────────────────────
const sortedSeasons = [...config.seasons].sort((a, b) => b.year - a.year);
const franchiseSeasons = sortedSeasons.filter(s => Object.keys(matchupsData[String(s.year)] ?? {}).length > 0);
const defaultSeasonYear = franchiseSeasons[0]?.year ?? sortedSeasons[0].year;
---

<Layout
  title={franchise.name}
  description={`Franchise profile for ${franchise.name} (${franchise.abbr}), owned by ${franchise.owner}. ${franchise.conference} — Sixth City Dynasty Football League.`}
>

  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">

    <!-- Franchise hero band -->
    <div style={`border-left: 4px solid ${primaryColor}; border-bottom: 1px solid var(--color-border); padding: 3rem 0 2.5rem 2rem; margin-top: 3rem;`}>
      <a href="/franchises" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.25rem;">
        &#8592; All Franchises
      </a>

      <div style="display: flex; align-items: flex-start; gap: 2rem; flex-wrap: wrap;">
        <img
          src={`/images/logos/${abbr}.png`}
          alt={`${franchise.name} logo`}
          width="72"
          height="72"
          style="object-fit: contain; flex-shrink: 0; margin-top: 0.25rem;"
          onerror="this.style.display='none'"
        />
        <div style="flex: 1; min-width: 260px;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
            <span style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-text-muted);">{franchise.abbr}</span>
            <span class={`label-badge badge-${franchise.conference.toLowerCase()}`}>{franchise.conference}</span>
            {(championships.length > 0 || runnerUps.length > 0 || confChamps.length > 0) && (
              <span style="display: flex; align-items: center; gap: 3px;">
                {Array.from({ length: championships.length }).map(() => (
                  <span style="display: inline-flex; align-items: flex-end; justify-content: center; width: 1.4rem; height: 1.4rem; color: var(--color-gold); font-size: 1.25rem; line-height: 1.3;">&#11042;</span>
                ))}
                {Array.from({ length: runnerUps.length }).map(() => (
                  <span style="display: inline-flex; align-items: flex-end; justify-content: center; width: 1.4rem; height: 1.4rem; color: var(--color-text-primary); font-size: 1.25rem; line-height: 1.3;">&#11041;</span>
                ))}
                {Array.from({ length: confChamps.length }).map(() => (
                  <span style={`display: inline-flex; align-items: center; justify-content: center; width: 1.4rem; height: 1.4rem; color: ${confColor}; font-size: 1rem; line-height: 1;`}>&#9650;</span>
                ))}
              </span>
            )}
          </div>
          <h1 style={`font-family: var(--font-display); font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 700; line-height: 1.1; color: var(--color-text-primary); margin: 0;`}>
            {franchise.name}
          </h1>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, auto); gap: 2rem; flex-shrink: 0; align-self: center;">
          <div>
            <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.2rem;">Owner</p>
            <p style="font-size: 0.95rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">{franchise.owner}</p>
          </div>
          <div>
            <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.2rem;">Founded</p>
            <p style="font-size: 0.95rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">{franchise.founded}</p>
          </div>
          <div>
            <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.2rem;">Colors</p>
            <div style="display: flex; gap: 5px; align-items: center; margin-top: 0.35rem;">
              {franchise.colors.map(c => (
                <span style={`display: inline-block; width: 16px; height: 16px; background-color: ${c}; border-radius: 50%;`} title={c}></span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Accolade key -->
    <div style="display: flex; align-items: center; gap: 1.5rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border); margin-top: 1rem;">
      <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-muted); margin: 0; flex-shrink: 0;">Key</p>
      <div style="display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap;">
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; color: var(--color-text-muted);">
          <span style="font-size: 1.1rem; color: var(--color-gold);">&#11042;</span> Championship
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; color: var(--color-text-muted);">
          <span style="font-size: 1.1rem; color: var(--color-text-primary);">&#11041;</span> Runner-Up
        </span>
        <span style="display: flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; color: var(--color-text-muted);">
          <span style={`font-size: 1rem; color: ${franchise.conference === 'SCC' ? 'var(--color-scc)' : 'var(--color-hcc)'};`}>&#9650;</span> Conf. Title
        </span>
      </div>
    </div>

    <div class="franchise-layout-grid" style="display: grid; grid-template-columns: 1fr 300px; gap: 3rem; margin-top: 3rem; align-items: start;">

      <!-- Main column -->
      <div class="franchise-main-col">

        <!-- Franchise notes markdown -->
        {FranchiseContent && (
          <div style="margin-bottom: 2rem;">
            <h2 style="font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--color-text-primary);">Franchise Notes</h2>
            <div style="font-size: 0.9rem; color: var(--color-text-secondary); text-align: justify; line-height: 1.7;">
              <FranchiseContent />
            </div>
          </div>
        )}

        <!-- Rebrand history -->
        {hasRebrands && (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem 1.5rem; margin-bottom: 2rem;">
            <p class="section-label" style="margin-bottom: 0.6rem;">Identity History</p>
            <div style="display: flex; flex-direction: column; gap: 0.3rem;">
              {franchise.rebrands
                .filter((r, i, arr) => i === 0 || arr[i-1].name !== r.name)
                .map((rebrand, i, arr) => {
                  const nextChange = arr[i + 1];
                  const endYear = nextChange ? nextChange.year - 1 : undefined;
                  return (
                    <div style="display: flex; align-items: baseline; gap: 0.75rem;">
                      <span style="font-size: 0.75rem; color: var(--color-text-muted); min-width: 60px;">
                        {rebrand.year}{endYear && endYear > rebrand.year ? `–${endYear}` : ''}
                      </span>
                      <span style="font-size: 0.875rem; color: var(--color-text-secondary);">{rebrand.name}</span>
                    </div>
                  );
                })
              }
              <div style="display: flex; align-items: baseline; gap: 0.75rem; margin-top: 0.1rem; padding-top: 0.3rem; border-top: 1px solid var(--color-border);">
                <span style="font-size: 0.75rem; color: var(--color-text-muted); min-width: 60px;">
                  {(() => {
                    const lastRebrand = franchise.rebrands[franchise.rebrands.length - 1];
                    if (!lastRebrand) return franchise.founded;
                    // If franchise name differs from last rebrand name, figure out when it changed
                    return lastRebrand.year + 1;
                  })()}–
                </span>
                <span style="font-size: 0.875rem; font-weight: 600; color: var(--color-text-primary);">{franchise.name} <span style="font-weight: 400; color: var(--color-text-muted); font-size: 0.8rem;">(current)</span></span>
              </div>
            </div>
            {abbr === 'SAR' && (
              <p style="font-size: 0.78rem; color: var(--color-text-muted); margin-top: 0.75rem; line-height: 1.5; border-top: 1px solid var(--color-border); padding-top: 0.75rem;">
                <em>Note: The 2021 SCC Championship won under the Montreal Generals (MTL) identity is part of this franchise's history.</em>
              </p>
            )}
          </div>
        )}

        <!-- Season record -->
        <div>
          <h2 style="font-family: var(--font-display); font-size: 1.35rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text-primary);">Season Record</h2>
          <div class="season-record-wrap" style="overflow-x: auto;">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Season</th>
                  {isAdopted && <th></th>}
                  <th>W</th>
                  <th>L</th>
                  <th class="col-hide-mobile" style="text-align: right;">PF</th>
                  <th class="col-hide-mobile" style="text-align: right;">PA</th>
                  <th>Result</th>
                </tr>
              </thead>
              <tbody>
                {franchiseResults.map(row => {
                  const seasonNotStarted = row.points_for === 0 && row.points_against === 0;
                  const isChamp = row.finish === 'Champion';
                  const isRunnerUp = row.finish === 'Runner-up';
                  const isPlayoff = row.playoff && !isChamp && !isRunnerUp;
                  const resultStyle = isChamp
                    ? 'color: var(--color-gold); font-weight: 600;'
                    : isRunnerUp
                    ? 'color: var(--color-text-secondary); font-weight: 600;'
                    : isPlayoff
                    ? 'color: var(--color-text-secondary);'
                    : 'color: var(--color-text-muted);';
                  return (
                  <tr>
                    <td style="font-weight: 600;">{row.year}</td>
                    {isAdopted && (
                      <td style="padding: 0.25rem 0.5rem; text-align: center;">
                        <img
                          src={`/images/logos/${row.year >= franchise.founded ? abbr : predecessorAbbr}.png`}
                          alt=""
                          width="24"
                          height="24"
                          style="object-fit: contain; vertical-align: middle;"
                          onerror="this.style.display='none'"
                        />
                      </td>
                    )}
                    {seasonNotStarted ? (
                      <>
                        <td colspan="4" class="season-not-started-desktop" style="color: var(--color-text-muted); text-align: center;">Season not yet started.</td>
                        <td colspan="2" class="season-not-started-mobile" style="color: var(--color-text-muted); text-align: center; display: none;">Season not started.</td>
                      </>
                    ) : (
                      <>
                        <td>{row.wins}</td>
                        <td>{row.losses}</td>
                        <td class="col-hide-mobile" style="text-align: right; font-variant-numeric: tabular-nums;">{row.points_for.toFixed(2)}</td>
                        <td class="col-hide-mobile" style="text-align: right; font-variant-numeric: tabular-nums;">{row.points_against.toFixed(2)}</td>
                      </>
                    )}
                    <td style={resultStyle}>{seasonNotStarted ? '—' : row.finish}</td>
                  </tr>
                  );
                })}
                {franchiseResults.length > 0 && (
                  <tr style={`background-color: ${primaryColor}33; border-left: 4px solid ${primaryColor};`}>
                    <td style="font-weight: 700;">Total</td>
                    {isAdopted && <td></td>}
                    <td style="font-weight: 700;">{totalWins}</td>
                    <td style="font-weight: 700;">{totalLosses}</td>
                    <td class="col-hide-mobile" style="text-align: right; font-variant-numeric: tabular-nums; font-weight: 700;">{totalPF.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    <td class="col-hide-mobile" style="text-align: right; font-variant-numeric: tabular-nums; font-weight: 700;">{totalPA.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}</td>
                    <td></td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">

        <!-- Quick facts -->
        <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem;">
          <p class="section-label">Franchise Facts</p>
          <dl style="display: flex; flex-direction: column; gap: 0.6rem;">
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <dt style="font-size: 0.75rem; color: var(--color-text-muted);">Conference</dt>
              <dd style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">
                <span class={`label-badge badge-${franchise.conference.toLowerCase()}`}>{franchise.conference}</span>
              </dd>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <dt style="font-size: 0.75rem; color: var(--color-text-muted);">Championships</dt>
              <dd style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">{championships.length}</dd>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <dt style="font-size: 0.75rem; color: var(--color-text-muted);">Bowl Appearances</dt>
              <dd style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">{dynastyBowlAppearances.length}</dd>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <dt style="font-size: 0.75rem; color: var(--color-text-muted);">Conf. Titles</dt>
              <dd style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">{confChamps.length}</dd>
            </div>
            <div style="display: flex; justify-content: space-between; align-items: baseline;">
              <dt style="font-size: 0.75rem; color: var(--color-text-muted);">Founded</dt>
              <dd style="font-size: 0.85rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">{franchise.founded}</dd>
            </div>
          </dl>
        </div>

        <!-- Championships -->
        {dynastyBowlAppearances.length > 0 && (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem;">
            <p class="section-label">Dynasty Bowl History</p>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              {dynastyBowlAppearances.map(s => {
                const won = allAbbrs.includes(s.dynasty_bowl.winner);
                const opp = won ? s.dynasty_bowl.loser : s.dynasty_bowl.winner;
                const oppFranchise = getOpponentFranchise(opp);
                return (
                  <div style={`padding: 0.75rem; border-left: 3px solid ${won ? 'var(--color-gold)' : 'var(--color-border-light)'}; background-color: var(--color-surface-alt);`}>
                    <p style={`font-size: 0.8rem; font-weight: 700; margin: 0 0 0.2rem; color: ${won ? 'var(--color-gold)' : 'var(--color-text-muted)'};`}>
                      {won ? 'Champion' : 'Runner-Up'} · {s.year}
                    </p>
                    <p style="font-size: 0.8rem; color: var(--color-text-secondary); margin: 0;">{s.dynasty_bowl.label}</p>
                    <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0.2rem 0 0;">
                      vs. <a href={`/franchises/${oppFranchise?.abbr}`} style="color: var(--color-text-muted);">{opp === 'MTL' ? 'MTL (SAR)' : opp}</a>
                    </p>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Conference Championships -->
        {confChamps.length > 0 && (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem;">
            <p class="section-label">Conference Titles</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
              {confChamps.map(s => (
                <span style="font-size: 0.8rem; font-weight: 600; padding: 0.2rem 0.6rem; background-color: var(--color-surface-alt); border: 1px solid var(--color-border-light); color: var(--color-text-secondary);">
                  {s.year}
                </span>
              ))}
            </div>
            <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.5rem;">{franchise.conference} Championship</p>
          </div>
        )}

        <!-- Bowl game affiliations -->
        {myBowlGames.length > 0 && (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem;">
            <p class="section-label">2026 Bowl Games</p>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              {myBowlGames.map(bg => {
                const oppAbbr = getBowlOpponent(bg);
                const opp = getOpponentFranchise(oppAbbr);
                return (
                  <a href={`/spotlight-games/${bg.slug}`} style="text-decoration: none; display: block; padding: 0.75rem; background-color: var(--color-surface-alt); border: 1px solid var(--color-border); transition: border-color 0.15s ease;" onmouseover="this.style.borderColor='var(--color-border-light)'" onmouseout="this.style.borderColor='var(--color-border)'">
                    <p style="font-family: var(--font-display); font-size: 0.9rem; font-weight: 600; color: var(--color-gold); margin: 0 0 0.2rem;">{bg.name}</p>
                    <p style="font-size: 0.75rem; color: var(--color-text-muted); margin: 0;">vs <span style="color: var(--color-text-secondary);">{opp?.name ?? oppAbbr}</span></p>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Rivalry game affiliations -->
        {myRivalryGames.length > 0 && (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.25rem;">
            <p class="section-label">2026 Rivalry Week</p>
            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              {myRivalryGames.map(rg => {
                const oppAbbr = getRivalryOpponent(rg);
                const opp = getOpponentFranchise(oppAbbr);
                return (
                  <a href={`/spotlight-games/${rg.slug}`} style="text-decoration: none; display: block; padding: 0.75rem; background-color: var(--color-surface-alt); border: 1px solid var(--color-border); transition: border-color 0.15s ease;" onmouseover="this.style.borderColor='var(--color-border-light)'" onmouseout="this.style.borderColor='var(--color-border)'">
                    <p style="font-family: var(--font-display); font-size: 0.9rem; font-weight: 600; color: var(--color-gold); margin: 0 0 0.2rem;">vs {opp?.name ?? oppAbbr}</p>
                  </a>
                );
              })}
            </div>
          </div>
        )}

      </div>
    </div>

    <!-- Games section -->
    {franchiseSeasons.length > 0 && (
      <div style="margin-top: 4rem;">
        <div style="padding-bottom: 2rem; border-bottom: 1px solid var(--color-border);">
          <h2 style="font-family: var(--font-display); font-size: 1.75rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text-primary);">Games</h2>

          <!-- Year selector -->
          <div style="display: flex; flex-direction: column; gap: 0.4rem; max-width: 180px;">
            <label for="franchise-season-select" style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">Season</label>
            <select id="franchise-season-select" style="font-family: var(--font-body); font-size: 0.9rem; color: var(--color-text-primary); background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 0.5rem 2rem 0.5rem 0.75rem; appearance: none; -webkit-appearance: none; background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22><path d=%22M0 0l5 6 5-6z%22 fill=%22%23888%22/></svg>'); background-repeat: no-repeat; background-position: right 0.6rem center; cursor: pointer;">
              {franchiseSeasons.map(s => (
                <option value={s.year} selected={s.year === defaultSeasonYear}>
                  {s.year} Season
                </option>
              ))}
            </select>
          </div>
        </div>

        <!-- All weeks grid (no pagination) -->
        <div id="franchise-games-grid" style="margin-top: 2rem; padding-bottom: 2rem;"></div>
      </div>
    )}

  </div>

  <!-- Bottom spacer -->
  <div style="height: 5rem;"></div>

</Layout>

<style>
  @media (max-width: 768px) {
    /* Stack sidebar below main column, both full width */
    .franchise-layout-grid {
      grid-template-columns: 1fr !important;
    }

    /* Constrain main column content to screen width */
    .franchise-main-col {
      min-width: 0;
      overflow-x: hidden;
    }

    /* Season record: remove horizontal scroll, let hidden columns do the work */
    .season-record-wrap {
      overflow-x: hidden;
    }

    /* Hide PF and PA columns */
    .col-hide-mobile {
      display: none;
    }

    /* Swap colspan elements for mobile */
    .season-not-started-desktop {
      display: none !important;
    }
    .season-not-started-mobile {
      display: table-cell !important;
    }
  }

  :global(.franchise-matchups-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 72ch;
  }

  :global(.franchise-matchup-card) {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  :global(.franchise-matchup-week-header) {
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  :global(.franchise-matchup-body) {
    display: flex;
    align-items: stretch;
  }

  :global(.franchise-matchup-teams) {
    flex: 1;
    min-width: 0;
  }

  :global(.franchise-recap-btn) {
    display: flex;
    align-items: center;
    padding: 0 1.1rem;
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
    border-left: 1px solid var(--color-border);
    color: var(--color-gold);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    letter-spacing: 0.03em;
  }

  :global(.franchise-team-row) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    transition: background-color 0.1s ease;
  }

  :global(.franchise-team-row + .franchise-team-row) {
    border-top: 1px solid var(--color-border);
  }

  :global(.franchise-team-row.winner) {
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  :global(.franchise-team-row.loser) {
    opacity: 0.55;
  }

  :global(.franchise-team-row.tied) {
    background-color: transparent;
  }

  :global(.franchise-team-logo) {
    width: 36px;
    height: 36px;
    object-fit: contain;
    flex-shrink: 0;
  }

  :global(.franchise-team-name) {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-primary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.franchise-team-score) {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    min-width: 3.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  :global(.franchise-team-row.winner .franchise-team-score) {
    color: var(--color-gold);
  }

  :global(.franchise-dynasty-bowl-banner) {
    background-color: var(--color-gold-surface);
    border-bottom: 1px solid var(--color-gold-glow);
    color: var(--color-gold);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.35rem 4rem;
  }

  :global(.franchise-no-games) {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 3rem 0;
    text-align: center;
  }
</style>

<script is:inline define:vars={{ matchupsData, franchiseMap, dynastyBowls, recapSlugsArr, defaultSeasonYear, abbr, franchise }}>
  const seasonSelect = document.getElementById('franchise-season-select');
  const grid = document.getElementById('franchise-games-grid');

  const franchiseId = franchise.id;
  const recapSlugs = new Set(recapSlugsArr); // "year/slug" keys

  function makeSlug(week, abbrA, abbrB) {
    const pad = String(week).padStart(2, '0');
    const [t1, t2] = [abbrA.toLowerCase(), abbrB.toLowerCase()].sort();
    return `${pad}-${t1}-${t2}`;
  }

  function getEffectiveAbbr(franchiseData, year) {
    if (franchiseData.founded !== 2021 && year < franchiseData.founded) {
      return franchiseData.predecessorAbbr ?? franchiseData.abbr;
    }
    return franchiseData.abbr;
  }

  function renderGames(year) {
    const yearStr = String(year);
    const allWeeks = matchupsData[yearStr] ?? {};

    // Collect all matchups for this franchise across all weeks
    const gamesByWeek = {};

    for (const [weekStr, entries] of Object.entries(allWeeks)) {
      const week = Number(weekStr);
      const franchiseMatches = entries.filter(e => e.roster_id === franchiseId);

      if (franchiseMatches.length === 0) continue;

      for (const franchiseEntry of franchiseMatches) {
        if (!franchiseEntry.matchup_id) continue;

        // Find opponent in same matchup
        const opponent = entries.find(
          e => e.matchup_id === franchiseEntry.matchup_id && e.roster_id !== franchiseId
        );

        if (!opponent) continue;

        if (!gamesByWeek[week]) gamesByWeek[week] = [];
        gamesByWeek[week].push({
          franchiseScore: franchiseEntry.score,
          opponentRosterId: opponent.roster_id,
          opponentScore: opponent.score,
        });
      }
    }

    const weeks = Object.keys(gamesByWeek)
      .map(Number)
      .sort((a, b) => a - b);

    if (weeks.length === 0) {
      grid.innerHTML = '<p class="franchise-no-games">No games available for this season.</p>';
      return;
    }

    let html = '';
    for (const week of weeks) {
      for (const game of gamesByWeek[week]) {
        const fOpponent = franchiseMap[game.opponentRosterId] ?? {
          name: `Roster ${game.opponentRosterId}`,
          abbr: 'UNKNOWN',
          founded: 2021,
          predecessorAbbr: null,
          rebrands: [],
        };

        const franchiseFranchise = franchiseMap[franchiseId];
        const scoreFranchise = game.franchiseScore;
        const scoreOpponent = game.opponentScore;
        const franchiseWins = scoreFranchise > scoreOpponent;
        const opponentWins = scoreOpponent > scoreFranchise;

        // Dynasty Bowl banner (week 17 only)
        let banner = '';
        if (week === 17) {
          const db = dynastyBowls[yearStr];
          if (db) {
            const abbrFranchise = getEffectiveAbbr(franchiseFranchise, year);
            const abbrOpponent = getEffectiveAbbr(fOpponent, year);
            if (
              (abbrFranchise === db.winner || abbrFranchise === db.loser) &&
              (abbrOpponent === db.winner || abbrOpponent === db.loser)
            ) {
              banner = `<div class="franchise-dynasty-bowl-banner">${db.label}</div>`;
            }
          }
        }

        const slug = makeSlug(week, franchiseFranchise.abbr, fOpponent.abbr);
        const gameUrl = `/games/${year}/${slug}`;
        const hasRecap = recapSlugs.has(`${year}/${slug}`);

        html += `
          <a class="franchise-matchup-card" href="${gameUrl}">
            ${banner}
            <div class="franchise-matchup-week-header">Week ${week}</div>
            <div class="franchise-matchup-body">
              <div class="franchise-matchup-teams">
                ${teamRow(franchiseFranchise, scoreFranchise, franchiseWins, opponentWins, year)}
                ${teamRow(fOpponent, scoreOpponent, opponentWins, franchiseWins, year)}
              </div>
              ${hasRecap ? `<div class="franchise-recap-btn">Recap&nbsp;→</div>` : ''}
            </div>
          </a>`;
      }
    }

    if (!html) {
      grid.innerHTML = '<p class="franchise-no-games">No games available for this season.</p>';
      return;
    }

    grid.innerHTML = `<div class="franchise-matchups-grid">${html}</div>`;
  }

  function teamRow(franchiseData, score, isWinner, isLoser, year) {
    const cls = isWinner ? 'winner' : isLoser ? 'loser' : 'tied';

    let name = franchiseData.name;
    let logoAbbr = franchiseData.abbr;
    if (franchiseData.founded !== 2021 && year < franchiseData.founded) {
      const rebrand = franchiseData.rebrands.find(r => r.year === year);
      if (rebrand) name = rebrand.name;
      if (franchiseData.predecessorAbbr) logoAbbr = franchiseData.predecessorAbbr;
    }

    return `
      <div class="franchise-team-row ${cls}">
        <img class="franchise-team-logo"
             src="/images/logos/${logoAbbr}.png"
             alt="${name}"
             onerror="this.style.display='none'" />
        <span class="franchise-team-name">${name}</span>
        <span class="franchise-team-score">${score.toFixed(2)}</span>
      </div>`;
  }

  // Wire up event listener
  seasonSelect?.addEventListener('change', () => {
    renderGames(Number(seasonSelect.value));
  });

  // Initial render
  renderGames(defaultSeasonYear);
</script>
