---
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';

// ── Fetch franchise data from Supabase ──────────────────────────────────────
const { data: franchisesRows, error: franchisesError } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('id, name, abbr')
  .is('to', null)
  .order('id');

if (franchisesError) throw new Error(`Franchises query failed: ${franchisesError.message}`);

// ── Fetch transaction data from Supabase (paginated) ────────────────────────
type TxRow = {
  transaction_id: string;
  year: number;
  week: number;
  type: string;
  status: string;
  roster_id: number;
};

const PAGE_SIZE = 1000;
const allTxRows: TxRow[] = [];
let offset = 0;

while (true) {
  const { data: page, error } = await supabase
    .schema('scdfl')
    .from('transactions')
    .select('transaction_id, year, week, type, status, roster_id')
    .range(offset, offset + PAGE_SIZE - 1);

  if (error) throw new Error(`Transactions query failed: ${error.message}`);
  allTxRows.push(...page);
  if (page.length < PAGE_SIZE) break;
  offset += PAGE_SIZE;
}

// ── Group rows by transaction_id to reconstruct per-transaction records ─────
// The Supabase table has one row per asset movement; the client JS expects one
// record per transaction with a roster_ids array of all involved franchises.
type TxRecord = {
  week: number;
  type: string;
  status: string;
  roster_ids: number[];
};

type TxData = Record<string, TxRecord[]>;
const txData: TxData = {};

// First pass: group rows by transaction_id
const txGroupMap = new Map<string, { year: number; week: number; type: string; status: string; rosterIds: Set<number> }>();

for (const row of allTxRows) {
  const existing = txGroupMap.get(row.transaction_id);
  if (existing) {
    existing.rosterIds.add(row.roster_id);
  } else {
    txGroupMap.set(row.transaction_id, {
      year: row.year,
      week: row.week,
      type: row.type,
      status: row.status,
      rosterIds: new Set([row.roster_id]),
    });
  }
}

// Second pass: build txData keyed by year
for (const group of txGroupMap.values()) {
  const yearKey = String(group.year);
  if (!txData[yearKey]) txData[yearKey] = [];
  txData[yearKey].push({
    week: group.week,
    type: group.type,
    status: group.status,
    roster_ids: Array.from(group.rosterIds),
  });
}

// ── Franchise lookup: id → { name, abbr } ──────────────────────────────────
type FranchiseEntry = {
  id: number;
  name: string;
  abbr: string;
};
const franchiseMap: Record<number, FranchiseEntry> = {};
const franchiseList: FranchiseEntry[] = [];
for (const f of franchisesRows) {
  franchiseMap[f.id] = {
    id: f.id,
    name: f.name,
    abbr: f.abbr,
  };
  franchiseList.push(franchiseMap[f.id]);
}

// Sort franchise list by name for dropdown
franchiseList.sort((a, b) => a.name.localeCompare(b.name));

// ── Collect available years from txData ──────────────────────────────────────
const availableYears = Object.keys(txData)
  .map(Number)
  .sort((a, b) => b - a); // Newest first
---

<Layout title="Transactions Audit - Commissioner Tools">
  <div style="max-width: 1400px; margin: 0 auto; padding: 2rem 1.5rem;">
    <h1 style="font-family: var(--font-display); font-size: 2rem; margin-bottom: 0.5rem;">Transactions Audit</h1>
    <p style="color: var(--color-text-muted); margin-bottom: 2rem;">
      Weekly transaction activity per franchise, broken down by type and completion status.
    </p>

    <!-- Selectors -->
    <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; align-items: flex-end;">
      <div>
        <label for="franchise-select" style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--color-text-muted); text-transform: uppercase; font-weight: 600;">Franchise</label>
        <select id="franchise-select" style="padding: 0.75rem; background-color: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-primary); border-radius: 4px; font-family: var(--font-body); font-size: 0.95rem; min-width: 200px;">
          <option value="">— Select a franchise —</option>
          {franchiseList.map(f => (
            <option value={f.id}>{f.abbr} • {f.name}</option>
          ))}
        </select>
      </div>

      <div>
        <label for="year-select" style="display: block; margin-bottom: 0.5rem; font-size: 0.9rem; color: var(--color-text-muted); text-transform: uppercase; font-weight: 600;">Year</label>
        <select id="year-select" style="padding: 0.75rem; background-color: var(--color-surface); border: 1px solid var(--color-border); color: var(--color-text-primary); border-radius: 4px; font-family: var(--font-body); font-size: 0.95rem; min-width: 120px;">
          <option value="">— Select a year —</option>
          {availableYears.map(y => (
            <option value={y}>{y}</option>
          ))}
        </select>
      </div>
    </div>

    <!-- Type filters -->
    <div style="margin-bottom: 2rem;">
      <label style="display: block; margin-bottom: 0.75rem; font-size: 0.9rem; color: var(--color-text-muted); text-transform: uppercase; font-weight: 600;">Transaction Types</label>
      <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
        {['waiver', 'free_agent', 'trade', 'commissioner'].map(type => (
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; user-select: none;">
            <input
              type="checkbox"
              class="type-checkbox"
              value={type}
              checked
              style="cursor: pointer;"
            />
            <span style="color: var(--color-text-primary); font-size: 0.9rem;">
              {type === 'free_agent' ? 'Free Agent' : type.charAt(0).toUpperCase() + type.slice(1)}
            </span>
          </label>
        ))}
      </div>
    </div>

    <!-- Results area -->
    <div id="results" style="margin-top: 2rem;">
      <!-- Rendered dynamically -->
    </div>
  </div>

  <style>
    :global(.tx-table) {
      width: 100%;
      border-collapse: collapse;
      background-color: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: 4px;
      overflow: hidden;
      margin-top: 1rem;
    }

    :global(.tx-table thead) {
      background-color: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
    }

    :global(.tx-table th) {
      padding: 0.75rem 0.75rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.85rem;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-right: 1px solid var(--color-border);
    }

    :global(.tx-table th:last-child) {
      border-right: none;
    }

    :global(.tx-table td) {
      padding: 0.75rem 0.75rem;
      font-size: 0.9rem;
      border-right: 1px solid var(--color-border);
      text-align: center;
    }

    :global(.tx-table td:last-child) {
      border-right: none;
    }

    :global(.tx-table tbody tr) {
      border-bottom: 1px solid var(--color-border);
    }

    :global(.tx-table tbody tr:last-child) {
      border-bottom: none;
    }

    :global(.tx-table tbody tr:hover) {
      background-color: rgba(255, 255, 255, 0.02);
    }

    :global(.tx-table tbody tr.grand-total) {
      font-weight: 600;
      border-top: 2px solid var(--color-border);
      border-bottom: none;
    }

    :global(.tx-type-cell) {
      text-align: left;
      color: var(--color-text-secondary);
      font-size: 0.85rem;
    }

    :global(.tx-count-cell) {
      font-variant-numeric: tabular-nums;
    }

    :global(.tx-count-cell.zero) {
      color: var(--color-text-muted);
    }

    :global(.tx-count-cell.has-failed) {
      background-color: rgba(243, 156, 18, 0.15);
      color: var(--color-text-primary);
    }

    :global(.tx-count-cell.high-activity) {
      background-color: rgba(242, 178, 46, 0.2);
      color: var(--color-text-primary);
    }

    :global(.week-label) {
      font-weight: 600;
      color: var(--color-text-primary);
      font-size: 0.9rem;
      padding-top: 1rem !important;
    }

    :global(.no-data) {
      text-align: center;
      padding: 3rem 1.5rem;
      color: var(--color-text-muted);
    }
  </style>

  <script define:vars={{ txData, franchiseMap }}>
    const franchiseSelect = document.getElementById('franchise-select');
    const yearSelect = document.getElementById('year-select');
    const typeCheckboxes = document.querySelectorAll('.type-checkbox');
    const resultsArea = document.getElementById('results');

    // Event listeners
    franchiseSelect.addEventListener('change', renderResults);
    yearSelect.addEventListener('change', renderResults);
    typeCheckboxes.forEach(cb => cb.addEventListener('change', renderResults));

    function renderResults() {
      const rosterIdStr = franchiseSelect.value;
      const yearStr = yearSelect.value;

      if (!rosterIdStr || !yearStr) {
        resultsArea.innerHTML = '<div class="no-data">Select a franchise and year to view transaction activity.</div>';
        return;
      }

      const rosterId = Number(rosterIdStr);
      const year = yearStr;
      const franchise = franchiseMap[rosterId];

      if (!franchise) {
        resultsArea.innerHTML = '<div class="no-data">Franchise not found.</div>';
        return;
      }

      const yearTxs = txData[year];
      if (!yearTxs) {
        resultsArea.innerHTML = '<div class="no-data">No data available for this year.</div>';
        return;
      }

      // Get checked types
      const checkedTypes = new Set();
      typeCheckboxes.forEach(cb => {
        if (cb.checked) checkedTypes.add(cb.value);
      });

      // Filter transactions for this franchise
      const franchiseTxs = yearTxs.filter(tx => tx.roster_ids.includes(rosterId));

      if (franchiseTxs.length === 0) {
        resultsArea.innerHTML = '<div class="no-data">No transaction activity found for this franchise in this year.</div>';
        return;
      }

      // Group by week, then by type
      const weekMap = {};
      for (const tx of franchiseTxs) {
        if (!weekMap[tx.week]) {
          weekMap[tx.week] = {};
        }
        if (!weekMap[tx.week][tx.type]) {
          weekMap[tx.week][tx.type] = { complete: 0, failed: 0 };
        }
        if (tx.status === 'complete') {
          weekMap[tx.week][tx.type].complete += 1;
        } else if (tx.status === 'failed') {
          weekMap[tx.week][tx.type].failed += 1;
        }
      }

      // Sort weeks
      const sortedWeeks = Object.keys(weekMap).map(Number).sort((a, b) => a - b);

      // Build table
      let html = `
        <div>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; margin: 0 0 1rem 0;">
            <strong>${franchise.abbr} • ${franchise.name}</strong> — ${year}
          </p>
          <table class="tx-table">
            <thead>
              <tr>
                <th style="min-width: 80px;">Week</th>
                <th style="min-width: 100px;">Type</th>
                <th style="min-width: 70px;">Completed</th>
                <th style="min-width: 70px;">Failed</th>
                <th style="min-width: 50px;">Total</th>
              </tr>
            </thead>
            <tbody>
      `;

      // Track totals for grand total row
      const grandTotals = {
        complete: 0,
        failed: 0,
      };

      // Render by week
      for (const week of sortedWeeks) {
        const typeData = weekMap[week];
        const weekRowCount = Array.from(checkedTypes).length;
        let isFirstRowOfWeek = true;

        // Render checked types
        for (const type of ['waiver', 'free_agent', 'trade', 'commissioner']) {
          if (!checkedTypes.has(type)) continue;

          const counts = typeData[type] || { complete: 0, failed: 0 };
          const total = counts.complete + counts.failed;

          // Determine cell classes for styling
          const completeClass = counts.complete === 0 ? 'tx-count-cell zero' : 'tx-count-cell';
          const failedClass = counts.failed > 0 ? 'tx-count-cell has-failed' : completeClass;
          const totalClass = total > 3 ? 'tx-count-cell high-activity' : (total === 0 ? 'tx-count-cell zero' : 'tx-count-cell');

          // Week label only on first row of the week
          let weekCell = '';
          if (isFirstRowOfWeek) {
            weekCell = `<td class="week-label" style="font-weight: 600; padding-top: 1rem;">W${String(week).padStart(2, '0')}</td>`;
          } else {
            weekCell = `<td class="week-label" style="visibility: hidden;"></td>`;
          }

          const typeLabel = type === 'free_agent' ? 'Free Agent' : type.charAt(0).toUpperCase() + type.slice(1);

          html += `
            <tr>
              ${weekCell}
              <td class="tx-type-cell">${typeLabel}</td>
              <td class="${completeClass}">${counts.complete}</td>
              <td class="${failedClass}">${counts.failed}</td>
              <td class="${totalClass}">${total}</td>
            </tr>
          `;

          grandTotals.complete += counts.complete;
          grandTotals.failed += counts.failed;
          isFirstRowOfWeek = false;
        }
      }

      // Grand totals row
      const grandTotal = grandTotals.complete + grandTotals.failed;
      const totalClass = grandTotal > 3 ? 'tx-count-cell high-activity' : 'tx-count-cell';

      html += `
            <tr class="grand-total">
              <td style="text-align: left; padding-top: 1rem;">TOTAL</td>
              <td style="text-align: left;"></td>
              <td class="tx-count-cell">${grandTotals.complete}</td>
              <td class="tx-count-cell">${grandTotals.failed}</td>
              <td class="${totalClass}">${grandTotal}</td>
            </tr>
          </tbody>
          </table>
        </div>
      `;

      resultsArea.innerHTML = html;
    }

    // Initial render
    renderResults();
  </script>
</Layout>
