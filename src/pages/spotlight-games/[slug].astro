---
import Layout from '../../layouts/Layout.astro';
import { getHistoricalMatchups } from '../../lib/get-historical-matchups';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const { createClient } = await import('@supabase/supabase-js');
  const sb = createClient(
    import.meta.env.SUPABASE_URL,
    import.meta.env.SUPABASE_ANON_KEY
  );

  // Determine current season year
  const { data: seasonRows, error: sError } = await sb
    .schema('scdfl')
    .from('seasons')
    .select('year')
    .order('year', { ascending: false })
    .limit(1);

  if (sError) throw new Error(`Seasons query failed: ${sError.message}`);
  const currentYear = seasonRows[0].year;

  // Get active spotlight game slugs (those with an entry for current year)
  const { data: activeSlugsRows, error: asError } = await sb
    .schema('scdfl')
    .from('spotlight_game_years')
    .select('slug')
    .eq('year', currentYear);

  if (asError) throw new Error(`Active slugs query failed: ${asError.message}`);
  const activeSlugs = new Set(activeSlugsRows.map(r => r.slug));

  // Fetch all year rows for active games (needed for year_established)
  const { data: gameYearRows, error: gyError } = await sb
    .schema('scdfl')
    .from('spotlight_game_years')
    .select('slug, year, spotlight_games(slug, name, type, team_a, team_b)')
    .in('slug', Array.from(activeSlugs));

  if (gyError) throw new Error(`Spotlight game years query failed: ${gyError.message}`);

  // Group by slug to compute year_established
  type GameData = {
    slug: string;
    name: string;
    type: string;
    team_a: string;
    team_b: string;
    year_established: number;
    description: string;
  };

  const gameMap = new Map<string, GameData>();
  for (const row of gameYearRows) {
    const game = row.spotlight_games as unknown as { slug: string; name: string; type: string; team_a: string; team_b: string };
    const existing = gameMap.get(row.slug);
    if (existing) {
      existing.year_established = Math.min(existing.year_established, row.year);
    } else {
      gameMap.set(row.slug, {
        slug: game.slug,
        name: game.name,
        type: game.type,
        team_a: game.team_a,
        team_b: game.team_b,
        year_established: row.year,
        description: '',
      });
    }
  }

  // Load descriptions from markdown files
  const contentDir = path.resolve('src/content/spotlight-games');
  for (const game of gameMap.values()) {
    const mdPath = path.join(contentDir, `${game.slug}.md`);
    try {
      game.description = fs.readFileSync(mdPath, 'utf-8').trim();
    } catch {
      // No file — leave empty
    }
  }

  // Fetch active franchises
  const { data: franchiseRows, error: fError } = await sb
    .schema('scdfl')
    .from('franchises')
    .select('id, abbr, name, owner, conf, colors')
    .is('to', null);

  if (fError) throw new Error(`Franchises query failed: ${fError.message}`);

  return Array.from(gameMap.values()).map(game => ({
    params: { slug: game.slug },
    props: { game, franchises: franchiseRows },
  }));
}

const { game, franchises } = Astro.props;

const teamA = franchises.find((f: any) => f.abbr === game.team_a);
const teamB = franchises.find((f: any) => f.abbr === game.team_b);
const historicalMatchups = await getHistoricalMatchups(game.team_a, game.team_b);

// Helper function to build game recap URL
function buildGameUrl(year: number, week: number, teamA: string, teamB: string): string {
  const teams = [teamA, teamB].sort();
  const weekPadded = String(week).padStart(2, '0');
  const slug = `${weekPadded}-${teams[0].toLowerCase()}-${teams[1].toLowerCase()}`;
  return `/games/${year}/${slug}`;
}
---

<Layout
  title={game.name}
  description={`${game.name} — ${game.team_a} vs. ${game.team_b}. Bowl Game, Sixth City Dynasty Football League.`}
>

  <div style="max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;">

    <!-- Header -->
    <div style="border-bottom: 1px solid var(--color-border); padding: 3rem 0 2.5rem; margin-top: 3rem;">
      <a href="/spotlight-games" style="font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted); text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem; margin-bottom: 1.25rem;">
        &#8592; Spotlight Games
      </a>

      <h1 class="page-title">{game.name}</h1>
      <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
        {game.year_established <= 2025 ? (
          <span style="font-size: 0.72rem; color: var(--color-text-muted); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;">Est. {game.year_established}</span>
        ) : (
          <span style="font-size: 0.72rem; color: var(--color-gold-dim); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;">Inaugural 2026</span>
        )}
      </div>
    </div>

    <!-- Matchup card -->
    <div style="margin-top: 2.5rem; background-color: var(--color-surface); border: 1px solid var(--color-border);">
      <div class="matchup-card-grid" style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: stretch;">

        <!-- Team A -->
        <a href={`/franchises/${teamA?.abbr}`} style="text-decoration: none; display: block;">
          <div style={`padding: 2rem; border-left: 4px solid ${teamA?.colors[0]}; border-right: 1px solid var(--color-border);`}>
            <img src={`/images/logos/${game.team_a}.png`} alt="" width="48" height="48" style="object-fit: contain; margin-bottom: 0.75rem; display: block;" onerror="this.style.display='none'" />
            <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.4rem;">{teamA?.abbr} &bull; <span class={`label-badge badge-${teamA?.conf.toLowerCase()}`}>{teamA?.conf}</span></p>
            <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.2;">{teamA?.name}</h2>
            <p style="font-size: 0.8rem; color: var(--color-text-muted); margin: 0;">Owner: {teamA?.owner}</p>
            <div style="display: flex; gap: 5px; margin-top: 0.75rem;">
              {teamA?.colors.map((c: string) => (
                <span style={`display: inline-block; width: 14px; height: 14px; background-color: ${c}; border-radius: 50%;`}></span>
              ))}
            </div>
          </div>
        </a>

        <!-- VS divider -->
        <div class="matchup-vs-divider" style="display: flex; align-items: center; justify-content: center; padding: 1.5rem; background-color: var(--color-surface-alt);">
          <div style="text-align: center;">
            <p style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-border-light); margin: 1.9rem 0 0; line-height: 1;">vs</p>
          </div>
        </div>

        <!-- Team B -->
        <a href={`/franchises/${teamB?.abbr}`} style="text-decoration: none; display: block;">
          <div class="matchup-team-b-inner" style={`padding: 2rem; border-right: 4px solid ${teamB?.colors[0]}; --team-b-color: ${teamB?.colors[0]};`}>
            <img src={`/images/logos/${game.team_b}.png`} alt="" width="48" height="48" style="object-fit: contain; margin-bottom: 0.75rem; display: block;" onerror="this.style.display='none'" />
            <p style="font-family: var(--font-body); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-text-muted); margin: 0 0 0.4rem;">{teamB?.abbr} &bull; <span class={`label-badge badge-${teamB?.conf.toLowerCase()}`}>{teamB?.conf}</span></p>
            <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-text-primary); margin: 0 0 0.5rem; line-height: 1.2;">{teamB?.name}</h2>
            <p style="font-size: 0.8rem; color: var(--color-text-muted); margin: 0;">Owner: {teamB?.owner}</p>
            <div style="display: flex; gap: 5px; margin-top: 0.75rem;">
              {teamB?.colors.map((c: string) => (
                <span style={`display: inline-block; width: 14px; height: 14px; background-color: ${c}; border-radius: 50%;`}></span>
              ))}
            </div>
          </div>
        </a>

      </div>
    </div>

    <!-- Description -->
    <div class="matchup-desc-grid" style="margin-top: 2.5rem; display: grid; grid-template-columns: 1fr 360px; gap: 2.5rem; align-items: start;">
      <div>
        <h2 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text-primary);">About This Matchup</h2>
        <p style="font-size: 0.95rem; text-align: justify; color: var(--color-text-secondary); line-height: 1.75; margin: 0;">
          {game.description}
        </p>
      </div>

        <!-- Historical results -->
      <div>
        <h2 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 600; margin-bottom: 1rem; color: var(--color-text-primary);">Historical Results</h2>
        <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 2rem;">
        Click a matchup for more details →
        </p>
        {historicalMatchups.length === 0 ? (
          <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.5rem; text-align: center;">
            <p style="font-size: 0.85rem; color: var(--color-text-muted); margin: 0;">
              {game.year_established === 2026
                ? 'These teams will meet for the first time in 2026.'
                : 'No historical matchups found.'}
            </p>
          </div>
        ) : (
          <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            {historicalMatchups.map((matchup) => {
              const isTeamAWinner = matchup.teamAScore > matchup.teamBScore;
              const isTeamBWinner = matchup.teamBScore > matchup.teamAScore;
              const gameUrl = buildGameUrl(matchup.year, matchup.week, game.team_a, game.team_b);
              return (
                <a href={gameUrl} style="text-decoration: none; display: block;">
                  <div style="display: grid; grid-template-columns: auto auto 1fr auto auto 1fr; gap: 0.75rem; align-items: center; padding: 0.75rem; background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px;">
                    <div style="font-weight: 600; font-size: 0.85rem; color: var(--color-text-muted); min-width: 45px;">
                      {matchup.year}
                    </div>
                    <div style="font-weight: 600; font-size: 0.85rem; color: var(--color-text-muted); min-width: 35px;">
                      Wk{matchup.week}
                    </div>
                    <div style={`color: ${isTeamAWinner ? 'var(--color-text-primary)' : 'var(--color-text-muted)'}; text-align: right; font-weight: 600;`}>
                      {game.team_a}
                    </div>
                    <div style={`background-color: ${isTeamAWinner ? 'var(--color-gold)' : 'rgba(255, 255, 255, 0.1)'}; color: ${isTeamAWinner ? '#000' : 'var(--color-text-muted)'}; padding: 0.4rem 0.6rem; border-radius: 3px; font-weight: 600; font-size: 0.85rem; min-width: 50px; text-align: center;`}>
                      {matchup.teamAScore.toFixed(1)}
                    </div>
                    <div style={`background-color: ${isTeamBWinner ? 'var(--color-gold)' : 'rgba(255, 255, 255, 0.1)'}; color: ${isTeamBWinner ? '#000' : 'var(--color-text-muted)'}; padding: 0.4rem 0.6rem; border-radius: 3px; font-weight: 600; font-size: 0.85rem; min-width: 50px; text-align: center;`}>
                      {matchup.teamBScore.toFixed(1)}
                    </div>
                    <div style={`color: ${isTeamBWinner ? 'var(--color-text-primary)' : 'var(--color-text-muted)'}; font-weight: 600;`}>
                      {game.team_b}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>

  </div>

  <div style="height: 5rem;"></div>

</Layout>

<style>
  @media (max-width: 768px) {
    /* Matchup card: vertical stack (Team A, vs, Team B) */
    .matchup-card-grid {
      grid-template-columns: 1fr !important;
    }

    /* VS divider: compact horizontal bar */
    .matchup-vs-divider {
      padding: 0.75rem 1.5rem !important;
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
    }

    .matchup-vs-divider p {
      margin: 0 !important;
    }

    /* Team B: swap color border from right to left */
    .matchup-team-b-inner {
      border-right: none !important;
      border-left: 4px solid var(--team-b-color) !important;
    }

    /* Description + Historical Results: single column */
    .matchup-desc-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
