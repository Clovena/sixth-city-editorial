---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import fs from 'node:fs';
import path from 'node:path';

// ── Determine current season year ───────────────────────────────────────────
const { data: seasonRows, error: sError } = await supabase
  .schema('scdfl')
  .from('seasons')
  .select('year')
  .order('year', { ascending: false })
  .limit(1);

if (sError) throw new Error(`Seasons query failed: ${sError.message}`);
const currentYear = seasonRows[0].year;

// ── Get active spotlight game slugs (those with an entry for current year) ──
const { data: activeSlugsRows, error: asError } = await supabase
  .schema('scdfl')
  .from('spotlight_game_years')
  .select('slug')
  .eq('year', currentYear);

if (asError) throw new Error(`Active slugs query failed: ${asError.message}`);
const activeSlugs = new Set(activeSlugsRows.map(r => r.slug));

// ── Fetch all year rows for active games (needed for year_established) ──────
const { data: gameYearRows, error: gyError } = await supabase
  .schema('scdfl')
  .from('spotlight_game_years')
  .select('slug, year, spotlight_games(slug, name, type, team_a, team_b)')
  .in('slug', Array.from(activeSlugs));

if (gyError) throw new Error(`Spotlight game years query failed: ${gyError.message}`);

// Group by slug to compute year_established = min(year) and flatten game data
type SpotlightGame = {
  slug: string;
  name: string;
  type: string;
  team_a: string;
  team_b: string;
  year_established: number;
  description: string;
};

const gameMap = new Map<string, SpotlightGame>();
for (const row of gameYearRows) {
  const game = row.spotlight_games as unknown as { slug: string; name: string; type: string; team_a: string; team_b: string };
  const existing = gameMap.get(row.slug);
  if (existing) {
    existing.year_established = Math.min(existing.year_established, row.year);
  } else {
    gameMap.set(row.slug, {
      slug: game.slug,
      name: game.name,
      type: game.type,
      team_a: game.team_a,
      team_b: game.team_b,
      year_established: row.year,
      description: '',
    });
  }
}

// Load descriptions from markdown files
const contentDir = path.resolve('src/content/spotlight-games');
for (const game of gameMap.values()) {
  const mdPath = path.join(contentDir, `${game.slug}.md`);
  try {
    game.description = fs.readFileSync(mdPath, 'utf-8').trim();
  } catch {
    // No file for this slug — leave description empty
  }
}

const spotlightGames = Array.from(gameMap.values());
const bowlGames = spotlightGames.filter(bg => bg.type === 'bowl-game');
const rivalryGames = spotlightGames.filter(rg => rg.type === 'rivalry');

// ── Fetch active franchises from Supabase ───────────────────────────────────
const { data: franchiseRows, error: fError } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('abbr, name, colors')
  .is('to', null);

if (fError) throw new Error(`Franchises query failed: ${fError.message}`);

const franchiseByAbbr = new Map(franchiseRows.map(f => [f.abbr, f]));

function getFranchise(abbr: string) {
  return franchiseByAbbr.get(abbr);
}
---

<Layout title="Spotlight Games" description="The 2026 Bowl Game slate and Rivalry Week for the Sixth City Dynasty Football League.">

  <div style="max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 0;">

    <!-- Page header -->
    <div style="padding-bottom: 2.5rem; border-bottom: 1px solid var(--color-border);">
      <p class="section-label">Spotlight Games</p>
      <h1 class="page-title">Bowl Games &amp; Rivalry Week</h1>
      <p class="page-subheader" style="margin-top: 0.75rem;">
        Institutional pairings that give the regular season shape and stakes. 
        <br><br>
        Bowl Games are persistent, named matchups that recur year to year; they are designed to build lore between pairs of franchises, one annual clash at a time.
        <br><br>
        Rivalry Week matchups are hand-selected to put the most compelling cross-conference and intra-conference rivalries on the field simultaneously. Unlike Bowl Games, the Rivalry Week pairings are fluid and can be revised each season.
      </p>
    </div>

    <!-- What are Bowl Games -->
    <div class="explain-grid" style="margin-top: 3rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div style="background-color: var(--color-green-surface); border: 1px solid var(--color-green-glow); padding: 1.75rem;">
        <p class="section-label">Bowl Games</p>
        <p style="font-size: 0.9rem; color: var(--color-text-secondary); text-align: justify; line-height: 1.65; margin: 0;">
          Each Bowl Game is a named, institutionalized rivalry matchup between two specific franchises. The pairing is fixed — the same two teams play their Bowl Game every season. These games are spread throughout the regular season schedule and carry the weight of a named tradition. Bowl Games return year to year unless officially dissolved.
        </p>
      </div>
      <div style="background-color: var(--color-red-surface); border: 1px solid var(--color-red-glow); padding: 1.75rem;">
        <p class="section-label">Rivalry Week</p>
        <p style="font-size: 0.9rem; color: var(--color-text-secondary); text-align: justify; line-height: 1.65; margin: 0;">
          Rivalry Week is a single designated week late in the regular season where all 7 matchups are rivalry pairings — cross-conference, historically contentious, or geographically meaningful. Unlike Bowl Games, Rivalry Week pairings can change year to year. It's the most watched week of the regular season.
        </p>
      </div>
    </div>

    <!-- 2026 Bowl Game Slate -->
    <div class="section-rule">
      <div style="display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 2rem;">
        <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin: 0; color: var(--color-text-primary);">2026 Bowl Game Slate</h2>
        <span style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted);">Weeks 5 thru 11</span>
      </div>

      <div style="display: flex; flex-direction: column; gap: 1px; background-color: var(--color-border);">
        {bowlGames.map(game => {
          const teamA = getFranchise(game.team_a);
          const teamB = getFranchise(game.team_b);
          return (
            <a href={`/spotlight-games/${game.slug}`} style="text-decoration: none; display: block;">
              <div class="bowl-card" style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center;">
                <div>
                  <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
                    <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-gold); margin: 0;">{game.name}</h3>
                    {game.year_established <= 2025 && (
                      <span style="font-size: 0.72rem; color: var(--color-text-muted); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;">Est. {game.year_established} · Recurring</span>
                    )}
                    {game.year_established === 2026 && (
                      <span style="font-size: 0.72rem; color: var(--color-gold-dim); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;">Inaugural 2026</span>
                    )}
                  </div>
                  <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.55; margin: 0; max-width: 65ch;">
                    {game.description.split('.')[0] + '.'}
                  </p>
                </div>

                <div class="bowl-teams-outer" style="text-align: right; flex-shrink: 0;">
                  <div class="bowl-teams-inner" style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
                    <div class="bowl-team-a" style="display: flex; align-items: center; gap: 0.6rem;">
                      <span class="bowl-team-name" style="font-size: 0.8rem; color: var(--color-text-secondary);">{teamA?.name}</span>
                      <img src={`/images/logos/${game.team_a}.png`} alt="" width="24" height="24" style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
                      <span style={`font-family: var(--font-body); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; padding: 0.15rem 0.45rem; background-color: ${teamA?.colors[0]}22; color: ${teamA?.colors[0]}; border: 1px solid ${teamA?.colors[0]}44;`}>{game.team_a}</span>
                    </div>
                    <div style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">vs.</div>
                    <div style="display: flex; align-items: center; gap: 0.6rem;">
                      <span class="bowl-team-name" style="font-size: 0.8rem; color: var(--color-text-secondary);">{teamB?.name}</span>
                      <img src={`/images/logos/${game.team_b}.png`} alt="" width="24" height="24" style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
                      <span style={`font-family: var(--font-body); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; padding: 0.15rem 0.45rem; background-color: ${teamB?.colors[0]}22; color: ${teamB?.colors[0]}; border: 1px solid ${teamB?.colors[0]}44;`}>{game.team_b}</span>
                    </div>
                  </div>
                </div>

              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Rivalry Week section -->
    <div class="section-rule" style="margin-bottom: 5rem;">
      <div style="display: flex; align-items: baseline; gap: 1.5rem; margin-bottom: 2rem;">
        <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin: 0; color: var(--color-text-primary);">2026 Rivalry Week Slate</h2>
        <span style="font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted);">Week 14</span>
      </div>

      <div style="display: flex; flex-direction: column; gap: 1px; background-color: var(--color-border);">
        {rivalryGames.map(game => {
          const teamA = getFranchise(game.team_a);
          const teamB = getFranchise(game.team_b);
          return (
            <a href={`/spotlight-games/${game.slug}`} style="text-decoration: none; display: block;">
              <div class="bowl-card" style="display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center;">
                <div>
                  <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
                    <h3 style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-gold); margin: 0;">{game.name}</h3>
                  </div>
                  <p style="font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.55; margin: 0; max-width: 65ch;">
                    {game.description.split('.')[0] + '.'}
                  </p>
                </div>

                <div class="bowl-teams-outer" style="text-align: right; flex-shrink: 0;">
                  <div class="bowl-teams-inner" style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem;">
                    <div class="bowl-team-a" style="display: flex; align-items: center; gap: 0.6rem;">
                      <span class="bowl-team-name" style="font-size: 0.8rem; color: var(--color-text-secondary);">{teamA?.name}</span>
                      <img src={`/images/logos/${game.team_a}.png`} alt="" width="24" height="24" style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
                      <span style={`font-family: var(--font-body); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; padding: 0.15rem 0.45rem; background-color: ${teamA?.colors[0]}22; color: ${teamA?.colors[0]}; border: 1px solid ${teamA?.colors[0]}44;`}>{game.team_a}</span>
                    </div>
                    <div style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-text-muted);">vs.</div>
                    <div style="display: flex; align-items: center; gap: 0.6rem;">
                      <span class="bowl-team-name" style="font-size: 0.8rem; color: var(--color-text-secondary);">{teamB?.name}</span>
                      <img src={`/images/logos/${game.team_b}.png`} alt="" width="24" height="24" style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
                      <span style={`font-family: var(--font-body); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; padding: 0.15rem 0.45rem; background-color: ${teamB?.colors[0]}22; color: ${teamB?.colors[0]}; border: 1px solid ${teamB?.colors[0]}44;`}>{game.team_b}</span>
                    </div>
                  </div>
                </div>

              </div>
            </a>
          );
        })}
      </div>
    </div>

  </div>
</Layout>

<style>
  @media (max-width: 768px) {
    /* "What are Bowl Games" info cards: stack vertically */
    .explain-grid {
      grid-template-columns: 1fr !important;
    }

    /* Bowl card: collapse to single column */
    .bowl-card {
      grid-template-columns: 1fr !important;
    }

    .bowl-team-name {
      display: none !important;
    }

    /* Teams outer: allow full width */
    .bowl-teams-outer {
      text-align: left !important;
    }

    /* Teams inner: switch from vertical column to horizontal row */
    .bowl-teams-inner {
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      gap: 0.5rem !important;
    }

    /* Team A: reverse order → badge | logo | name (name closest to "vs.") */
    .bowl-team-a {
      flex-direction: row-reverse !important;
    }
  }
</style>
