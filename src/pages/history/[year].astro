---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';
import { getEntry, render } from 'astro:content';

// ── Fetch all season years for static paths ────────────────────────────────

export async function getStaticPaths() {
  const { supabase: sb } = await import('../../lib/supabase');
  const { data: rows } = await sb.schema('scdfl').from('seasons').select('year');
  return (rows ?? []).map(s => ({ params: { year: String(s.year) } }));
}

const { year } = Astro.params;
const yearNum = parseInt(year);

// ── Fetch season data ──────────────────────────────────────────────────────

const { data: seasonRow, error: sErr } = await supabase
  .schema('scdfl')
  .from('seasons')
  .select('year, scc_champion, hcc_champion, playoff_teams')
  .eq('year', yearNum)
  .single();

if (sErr) throw new Error(`Season query failed: ${sErr.message}`);

// ── Fetch franchise identities for this year ───────────────────────────────

const { data: yearFranchises, error: yfErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('id, sleeper_id, abbr, name, owner, conf, colors, "from", "to"')
  .lte('from', yearNum)
  .or(`to.gte.${yearNum},to.is.null`);

if (yfErr) throw new Error(`Year franchises query failed: ${yfErr.message}`);

// Active franchises (current identity) for linking
const { data: activeFranchises, error: afErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('id, sleeper_id, abbr, name, owner, conf, colors')
  .is('to', null);

if (afErr) throw new Error(`Active franchises query failed: ${afErr.message}`);

// Maps: sleeper_id → year-appropriate identity, and sleeper_id → active identity
const yearIdentityBySleeperId = new Map(yearFranchises.map(f => [f.sleeper_id, f]));
const activeBySleeperId = new Map(activeFranchises.map(f => [f.sleeper_id, f]));

// ── Fetch results for this year ────────────────────────────────────────────

const { data: resultRows, error: rErr } = await supabase
  .schema('scdfl')
  .from('results')
  .select('sleeper_id, year, wins, losses, points_for, points_against, playoff, seed, finish')
  .eq('year', yearNum);

if (rErr) throw new Error(`Results query failed: ${rErr.message}`);

// ── Exhibition data ─────────────────────────────────────────────────────────

const { data: exhibRows, error: exErr } = await supabase
  .schema('scdfl')
  .from('exhibitions')
  .select(`
    id, year, week, exhib_type,
    team_a_slug, team_a_display_name, team_a_members,
    team_b_slug, team_b_display_name, team_b_members,
    exhibition_matchups(score_a, score_b)
  `)
  .eq('year', yearNum);

if (exErr) throw new Error(`Exhibitions query failed: ${exErr.message}`);

const yearExhibitions = (exhibRows ?? []).map(e => {
  const match = (e.exhibition_matchups as any)?.[0] ?? e.exhibition_matchups ?? {};
  const slugParts = [e.team_a_slug, e.team_b_slug].sort((a: string, b: string) => a.localeCompare(b)).map((s: string) => s.toLowerCase());
  const slug = `${String(e.week).padStart(2, '0')}-${slugParts[0]}-${slugParts[1]}`;
  return {
    year: e.year,
    week: e.week,
    slug,
    exhib_type: e.exhib_type,
    team_a: { display_name: e.team_a_display_name, members: e.team_a_members, score: match.score_a ?? 0 },
    team_b: { display_name: e.team_b_display_name, members: e.team_b_members, score: match.score_b ?? 0 },
  };
});

// ── Franchise helpers ───────────────────────────────────────────────────────

function getEffectiveAbbr(sleeperId: string): string {
  return yearIdentityBySleeperId.get(sleeperId)?.abbr ?? activeBySleeperId.get(sleeperId)?.abbr ?? '???';
}

function getActiveAbbr(sleeperId: string): string {
  return activeBySleeperId.get(sleeperId)?.abbr ?? '???';
}

// ── Position color mapping ──────────────────────────────────────────────────

const POSITION_COLOR_MAP: Record<string, string> = {
  QB: 'red',
  RB: 'green', FB: 'green',
  WR: 'scc',
  TE: 'gold',
  K: 'grey', PK: 'grey',
  DT: 'hcc', DE: 'hcc', DL: 'hcc', NT: 'hcc',
  LB: 'purple', ILB: 'purple', OLB: 'purple', MLB: 'purple',
  CB: 'pink', S: 'pink', SS: 'pink', FS: 'pink', DB: 'pink',
};

// ── Roman numeral helper ───────────────────────────────────────────────────

function toRoman(n: number): string {
  const vals = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const syms = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let result = '';
  for (let i = 0; i < vals.length; i++) {
    while (n >= vals[i]) { result += syms[i]; n -= vals[i]; }
  }
  return result;
}

const dynastyBowlLabel = `Dynasty Bowl ${toRoman(yearNum - 2020)}`;

// ── Standings ───────────────────────────────────────────────────────────────

const FINISH_ORDER: Record<string, number> = {
  'Champion': 1,
  'Runner-up': 2,
  'Semifinals': 3,
  'First round': 4,
};

function finishSortKey(finish: string | null): number {
  if (!finish) return 999;
  if (FINISH_ORDER[finish] !== undefined) return FINISH_ORDER[finish];
  const m = finish.match(/^(\d+)/);
  return m ? 100 + parseInt(m[1]) : 999;
}

type StandingsRow = {
  abbr: string;
  effectiveAbbr: string;
  name: string;
  effectiveName: string;
  conference: string;
  wins: number;
  losses: number;
  points_for: number;
  points_against: number;
  playoff: boolean;
  finish: string | null;
  seed: number;
  roster_id: number;
};

const allRows: StandingsRow[] = [];

for (const r of resultRows) {
  if (r.wins === 0 && r.losses === 0 && !r.finish) continue;

  const yearIdentity = yearIdentityBySleeperId.get(r.sleeper_id);
  const activeIdentity = activeBySleeperId.get(r.sleeper_id);
  if (!yearIdentity && !activeIdentity) continue;

  allRows.push({
    abbr: activeIdentity?.abbr ?? yearIdentity!.abbr,
    effectiveAbbr: yearIdentity?.abbr ?? activeIdentity!.abbr,
    name: activeIdentity?.name ?? yearIdentity!.name,
    effectiveName: yearIdentity?.name ?? activeIdentity!.name,
    conference: activeIdentity?.conf ?? yearIdentity!.conf,
    wins: r.wins,
    losses: r.losses,
    points_for: r.points_for,
    points_against: r.points_against,
    playoff: Boolean(r.playoff),
    finish: r.finish,
    seed: r.seed ?? 0,
    roster_id: parseInt(r.sleeper_id),
  });
}

function sortStandings(rows: StandingsRow[]): StandingsRow[] {
  return [...rows].sort((a, b) => {
    if (b.wins !== a.wins) return b.wins - a.wins;
    if (a.playoff !== b.playoff) return a.playoff ? -1 : 1;
    const fa = finishSortKey(a.finish);
    const fb = finishSortKey(b.finish);
    if (fa !== fb) return fa - fb;
    return b.points_for - a.points_for;
  });
}

const sccRows = sortStandings(allRows.filter(r => r.conference === 'SCC'));
const hccRows = sortStandings(allRows.filter(r => r.conference === 'HCC'));

// ── Playoff bracket ─────────────────────────────────────────────────────────

const is8Team = (seasonRow.playoff_teams ?? 7) >= 8;

const playoffTeams = allRows.filter(r => r.seed > 0);

function getByConfSeed(conf: string, seed: number): StandingsRow | null {
  return playoffTeams.find(r => r.conference === conf && r.seed === seed) ?? null;
}
function getBySeed(seed: number): StandingsRow | null {
  return playoffTeams.find(r => r.seed === seed) ?? null;
}

// Playoff matchup data from Supabase (game_type = 1)
const { data: playoffMatchups, error: pmErr } = await supabase
  .schema('scdfl')
  .from('matchups')
  .select('week, matchup_id, roster_id_a, roster_id_b, score_a, score_b')
  .eq('year', yearNum)
  .eq('game_type', 1);

if (pmErr) throw new Error(`Playoff matchups query failed: ${pmErr.message}`);

// Group week 15 matchups for first-round winner resolution
const matchupById = new Map<number, { roster_id: number; score: number }[]>();
for (const m of (playoffMatchups ?? []).filter(m => m.week === 15)) {
  // Each row is already a pair (roster_id_a vs roster_id_b)
  matchupById.set(m.matchup_id, [
    { roster_id: m.roster_id_a, score: m.score_a ?? 0 },
    { roster_id: m.roster_id_b, score: m.score_b ?? 0 },
  ]);
}

// Build slug for game recap link: [week]-[abbr1]-[abbr2] (alphabetized, lowercased)
function buildSlug(teamA: StandingsRow | null | undefined, teamB: StandingsRow | null | undefined, week: number): string | null {
  if (!teamA || !teamB) return null;
  const abbrs = [teamA.effectiveAbbr, teamB.effectiveAbbr].sort().map(a => a.toLowerCase());
  return `${String(week).padStart(2, '0')}-${abbrs[0]}-${abbrs[1]}`;
}

// Return winner of a matchup between two teams; if b is null, a gets a bye
function getMatchupWinner(a: StandingsRow | null, b: StandingsRow | null): StandingsRow | null {
  if (!a) return null;
  if (!b) return a; // bye
  for (const entries of matchupById.values()) {
    const ea = entries.find(e => e.roster_id === a.roster_id);
    const eb = entries.find(e => e.roster_id === b.roster_id);
    if (ea && eb) return ea.score > eb.score ? a : b;
  }
  return null;
}

// Bracket matchups: each is [topSlot, bottomSlot]
// 8-team: SCC on left (1v4 top, 2v3 bottom), HCC on right (1v4 top, 2v3 bottom)
// 7-team: left = [seed1(bye), null] + [seed4, seed5], right = [seed2, seed7] + [seed3, seed6]
let leftTop:    [StandingsRow | null, StandingsRow | null];
let leftBottom: [StandingsRow | null, StandingsRow | null];
let rightTop:   [StandingsRow | null, StandingsRow | null];
let rightBottom:[StandingsRow | null, StandingsRow | null];

if (is8Team) {
  leftTop    = [getByConfSeed('SCC', 1), getByConfSeed('SCC', 4)];
  leftBottom = [getByConfSeed('SCC', 2), getByConfSeed('SCC', 3)];
  rightTop   = [getByConfSeed('HCC', 1), getByConfSeed('HCC', 4)];
  rightBottom= [getByConfSeed('HCC', 2), getByConfSeed('HCC', 3)];
} else {
  leftTop    = [getBySeed(1), null]; // seed 1 has a bye
  leftBottom = [getBySeed(4), getBySeed(5)];
  rightTop   = [getBySeed(2), getBySeed(7)];
  rightBottom= [getBySeed(3), getBySeed(6)];
}

// Semi-slot winners derived from week 15 matchup data
const leftSemiTop    = getMatchupWinner(leftTop[0], leftTop[1]);
const leftSemiBottom = getMatchupWinner(leftBottom[0], leftBottom[1]);
const rightSemiTop   = getMatchupWinner(rightTop[0], rightTop[1]);
const rightSemiBottom= getMatchupWinner(rightBottom[0], rightBottom[1]);

// Derive champion/runner-up from week 17 championship matchup
const champMatch = (playoffMatchups ?? []).find(m => m.week === 17);
let champion: StandingsRow | undefined;
let runnerUp: StandingsRow | undefined;
if (champMatch) {
  const aWins = champMatch.score_a > champMatch.score_b;
  const winnerRosterId = aWins ? champMatch.roster_id_a : champMatch.roster_id_b;
  const loserRosterId = aWins ? champMatch.roster_id_b : champMatch.roster_id_a;
  champion = allRows.find(r => r.roster_id === winnerRosterId);
  runnerUp = allRows.find(r => r.roster_id === loserRosterId);
}

// ── Draft boards ────────────────────────────────────────────────────────────

type DraftCell = {
  playerId: string | null;
  playerName: string;
  position: string;
  colorVar: string;
  pickLabel: string;
  isTrade: boolean;
  tradeToAbbr: string | null;
};

type DraftBoard = {
  draft_id: number;
  type: string;
  numRounds: number;
  numSlots: number;
  headers: { slot: number; abbr: string }[];
  grid: (DraftCell | null)[][];
};

const draftBoards: DraftBoard[] = [];

// Fetch drafts for this year
const { data: draftRows, error: dErr } = await supabase
  .schema('scdfl')
  .from('drafts')
  .select('draft_id, year, type')
  .eq('year', yearNum);

if (dErr) throw new Error(`Drafts query failed: ${dErr.message}`);

for (const draft of (draftRows ?? [])) {
  // Fetch all picks for this draft with player info
  const { data: pickRows, error: pErr } = await supabase
    .schema('scdfl')
    .from('draft_results')
    .select('pick_no, round, draft_slot, roster_id, original_roster_id, player_id, players(first_name, last_name, fantasy_positions)')
    .eq('draft_id', draft.draft_id)
    .order('pick_no')
    .limit(500);

  if (pErr) throw new Error(`Draft results query failed: ${pErr.message}`);
  if (!pickRows?.length) continue;

  const numRounds = Math.max(...pickRows.map(p => p.round));
  // Derive numSlots from distinct draft_slot values
  const slotSet = new Set(pickRows.map(p => p.draft_slot));
  const numSlots = Math.max(...slotSet);

  // Build roster_id → franchise map for header + trade display
  const rosterIdToSleeperId = new Map(activeFranchises.map(f => [parseInt(f.sleeper_id), f.sleeper_id]));

  // Organize picks by round and draft_slot
  const pickGrid = new Map<number, Map<number, any>>();
  for (const pick of pickRows) {
    if (!pickGrid.has(pick.round)) pickGrid.set(pick.round, new Map());
    pickGrid.get(pick.round)!.set(pick.draft_slot, pick);
  }

  // Build column headers from original_roster_id per slot
  // Use first pick in each slot to determine the original owner
  const headers: { slot: number; abbr: string }[] = [];
  for (let s = 1; s <= numSlots; s++) {
    let originalRosterId: number | null = null;
    for (let r = 1; r <= numRounds; r++) {
      const pick = pickGrid.get(r)?.get(s);
      if (pick?.original_roster_id != null) {
        originalRosterId = pick.original_roster_id;
        break;
      }
    }
    const sleeperId = originalRosterId != null ? String(originalRosterId) : null;
    const abbr = sleeperId ? getEffectiveAbbr(sleeperId) : '???';
    headers.push({ slot: s, abbr });
  }

  // Build grid rows
  const grid: (DraftCell | null)[][] = [];
  for (let r = 1; r <= numRounds; r++) {
    const row: (DraftCell | null)[] = [];
    for (let s = 1; s <= numSlots; s++) {
      const pick = pickGrid.get(r)?.get(s) ?? null;
      if (!pick) {
        row.push(null);
        continue;
      }

      const player = pick.players as any;
      const fantasyPositions: string[] = player?.fantasy_positions ?? [];
      const position = fantasyPositions.join(',').toUpperCase();
      const firstPos = (fantasyPositions[0] ?? '').toUpperCase();
      const colorVar = POSITION_COLOR_MAP[firstPos] ?? 'white';
      const pickLabel = `${pick.round}.${String(((pick.pick_no - 1) % 14) + 1).padStart(2, '0')}`;
      const playerName = `${player?.first_name ?? ''} ${player?.last_name ?? ''}`.trim();

      const isTrade = pick.original_roster_id != null && pick.roster_id !== pick.original_roster_id;
      const tradeToSleeperId = isTrade ? String(pick.roster_id) : null;
      const tradeToAbbr = tradeToSleeperId ? getEffectiveAbbr(tradeToSleeperId) : null;

      row.push({ playerId: pick.player_id ?? null, playerName, position, colorVar, pickLabel, isTrade, tradeToAbbr });
    }
    grid.push(row);
  }

  draftBoards.push({ draft_id: draft.draft_id, type: draft.type, numRounds, numSlots, headers, grid });
}

// Sort draft boards by draft_id ascending
draftBoards.sort((a, b) => a.draft_id - b.draft_id);

// ── Season summary markdown ──────────────────────────────────────────────────

const seasonEntry = await getEntry('seasons', year);
const { Content: SeasonSummary } = seasonEntry ? await render(seasonEntry) : { Content: null };
---

<Layout
  title={`${yearNum} Season`}
  description={`${yearNum} SCDFL season recap: standings, playoff bracket, and ${dynastyBowlLabel} results.`}
>
  <div style="max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 0;">

    <!-- Breadcrumb -->
    <nav style="margin-bottom: 2rem; font-size: 0.8rem; color: var(--color-text-muted);">
      <a href="/history" style="color: var(--color-text-muted);">History</a>
      <span style="margin: 0 0.5rem;">/</span>
      <span style="color: var(--color-text-primary);">{yearNum}</span>
    </nav>

    <!-- Page header -->
    <div>
      <p class="section-label">Season Archive</p>
      <h1 class="page-title">{yearNum} Season</h1>
      <p style="font-size: 0.9rem; color: var(--color-text-muted); margin-top: 0.5rem;">
        {dynastyBowlLabel} &bull;
        Won by <strong style="color: var(--color-text-primary);">{champion?.effectiveAbbr}</strong>
        {' '}over <strong style="color: var(--color-text-primary);">{runnerUp?.effectiveAbbr}</strong>
      </p>
    </div>

    <!-- Season summary -->
    {SeasonSummary ? 
    <div class="section-rule">
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 1.25rem;">Season Summary</h2>
      <div class="season-summary" style="max-width: 72ch; font-size: 0.95rem; color: var(--color-text-secondary); text-align: justify; line-height: 1.7;">
        <SeasonSummary />
      </div>
    </div> : <div></div>}

    <!-- Conference standings -->
    <div class="section-rule">
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">Final Standings</h2>
      <div class="standings-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">

        <!-- SCC -->
        <div>
          <h3 style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-scc); margin-bottom: 0.75rem;">Senatorial Canadian Conference</h3>
          <table class="data-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Team</th>
                <th>W</th>
                <th>L</th>
                <th>PF</th>
                <th class="col-hide-mobile">PA</th>
                <th style="text-align: right;">Finish</th>
              </tr>
            </thead>
            <tbody>
              {sccRows.map(row => (
                <tr>
                  <td style="text-align: left;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <img src={`/images/logos/${row.effectiveAbbr}.png`} alt="" width="20" height="20"
                        style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
                      <a href={`/franchises/${row.abbr}`}
                        style={`font-size: 0.85rem; ${row.playoff ? 'color: var(--color-text-primary); font-weight: 600;' : 'color: var(--color-text-muted);'}`}>
                        {row.effectiveAbbr}
                      </a>
                    </div>
                  </td>
                  <td style="text-align: left;">{row.wins}</td>
                  <td style="text-align: left;">{row.losses}</td>
                  <td style="text-align: left; font-size: 0.8rem;">{row.points_for.toFixed(2)}</td>
                  <td class="col-hide-mobile" style="text-align: left; font-size: 0.8rem;">{row.points_against.toFixed(2)}</td>
                  <td style="text-align: right;">
                    <span style={`font-size: 0.75rem; ${row.finish === 'Champion' ? 'color: var(--color-gold); font-weight: 700;' : row.finish === 'Runner-up' ? 'color: var(--color-text-primary);' : row.playoff ? 'color: var(--color-text-secondary);' : 'color: var(--color-text-muted);'}`}>
                      {row.finish}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- HCC -->
        <div>
          <h3 style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-hcc); margin-bottom: 0.75rem;">House of Commons Conference</h3>
          <table class="data-table" style="width: 100%;">
            <thead>
              <tr>
                <th style="text-align: left;">Team</th>
                <th>W</th>
                <th>L</th>
                <th>PF</th>
                <th class="col-hide-mobile">PA</th>
                <th style="text-align: right;">Finish</th>
              </tr>
            </thead>
            <tbody>
              {hccRows.map(row => (
                <tr>
                  <td style="text-align: left;">
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <img src={`/images/logos/${row.effectiveAbbr}.png`} alt="" width="20" height="20"
                        style="object-fit: contain; flex-shrink: 0;" onerror="this.style.display='none'" />
                      <a href={`/franchises/${row.abbr}`}
                        style={`font-size: 0.85rem; ${row.playoff ? 'color: var(--color-text-primary); font-weight: 600;' : 'color: var(--color-text-muted);'}`}>
                        {row.effectiveAbbr}
                      </a>
                    </div>
                  </td>
                  <td style="text-align: left;">{row.wins}</td>
                  <td style="text-align: left;">{row.losses}</td>
                  <td style="text-align: left; font-size: 0.8rem;">{row.points_for.toFixed(2)}</td>
                  <td class="col-hide-mobile" style="text-align: left; font-size: 0.8rem;">{row.points_against.toFixed(2)}</td>
                  <td style="text-align: right;">
                    <span style={`font-size: 0.75rem; ${row.finish === 'Champion' ? 'color: var(--color-gold); font-weight: 700;' : row.finish === 'Runner-up' ? 'color: var(--color-text-primary);' : row.playoff ? 'color: var(--color-text-secondary);' : 'color: var(--color-text-muted);'}`}>
                      {row.finish}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

      </div>
    </div>

    <!-- Playoff bracket -->
    <div class="section-rule">
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 0.5rem;">Playoff Bracket</h2>
      <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-bottom: 2rem;">
        Click a matchup for more details →
      </p>

      <div class="bracket-wrap">

        <!-- LEFT SIDE: round1 → semis → center -->
        <div class="bracket-side bracket-left">

          <!-- Round 1 (left) -->
          <div class="bracket-round">
            <!-- Top matchup -->
            {(() => {
              const slug = buildSlug(leftTop[0], leftTop[1], 15);
              const matchupContent = (
                <div class="bracket-matchup">
                  <div class={`bracket-slot top${!is8Team && leftTop[1] === null ? ' bye-slot' : ''}`}>
                    {leftTop[0] && (
                      <>
                        <img src={`/images/logos/${leftTop[0].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{leftTop[0].seed}</span>
                        <span class="slot-name">{leftTop[0].effectiveAbbr}</span>
                        {!is8Team && leftTop[1] === null && <span class="bye-label">BYE</span>}
                      </>
                    )}
                  </div>
                  {leftTop[1] !== null && (
                    <>
                      <div class="bracket-connector-v"></div>
                      <div class="bracket-slot bottom">
                        {leftTop[1] && (
                          <>
                            <img src={`/images/logos/${leftTop[1].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                            <span class="slot-seed">{leftTop[1].seed}</span>
                            <span class="slot-name">{leftTop[1].effectiveAbbr}</span>
                          </>
                        )}
                      </div>
                    </>
                  )}
                </div>
              );
              return slug ? <a href={`/games/${year}/${slug}`} class="bracket-matchup-link">{matchupContent}</a> : matchupContent;
            })()}
            <!-- Bottom matchup -->
            {(() => {
              const slug = buildSlug(leftBottom[0], leftBottom[1], 15);
              const matchupContent = (
                <div class="bracket-matchup">
                  <div class="bracket-slot top">
                    {leftBottom[0] && (
                      <>
                        <img src={`/images/logos/${leftBottom[0].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{leftBottom[0].seed}</span>
                        <span class="slot-name">{leftBottom[0].effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                  <div class="bracket-connector-v"></div>
                  <div class="bracket-slot bottom">
                    {leftBottom[1] && (
                      <>
                        <img src={`/images/logos/${leftBottom[1].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{leftBottom[1].seed}</span>
                        <span class="slot-name">{leftBottom[1].effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                </div>
              );
              return slug ? <a href={`/games/${year}/${slug}`} class="bracket-matchup-link">{matchupContent}</a> : matchupContent;
            })()}
          </div>

          <!-- Semis (left) -->
          <div class="bracket-round bracket-round-semis">
            {(() => {
              const slug = buildSlug(leftSemiTop, leftSemiBottom, 16);
              const matchupContent = (
                <div class="bracket-matchup">
                  <div class="bracket-slot semi-slot top">
                    {leftSemiTop && (
                      <>
                        <img src={`/images/logos/${leftSemiTop.effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{leftSemiTop.seed}</span>
                        <span class="slot-name">{leftSemiTop.effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                  <div class="bracket-connector-v"></div>
                  <div class="bracket-slot semi-slot bottom">
                    {leftSemiBottom && (
                      <>
                        <img src={`/images/logos/${leftSemiBottom.effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{leftSemiBottom.seed}</span>
                        <span class="slot-name">{leftSemiBottom.effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                </div>
              );
              return slug ? <a href={`/games/${year}/${slug}`} class="bracket-matchup-link">{matchupContent}</a> : matchupContent;
            })()}
          </div>

        </div><!-- end bracket-left -->

        <!-- CENTER / FINAL -->
        <div class="bracket-center">
          <div class="bracket-final-label">
            <p class="section-label" style="text-align: center; margin-bottom: 0.5rem;">{dynastyBowlLabel}</p>
          </div>
          {(() => {
            const slug = buildSlug(champion, runnerUp, 17);
            const finalContent = (
              <div class="bracket-final-slot">
                {champion && (
                  <div class="final-team champion-team">
                    <img src={`/images/logos/${champion.effectiveAbbr}.png`} alt="" width="32" height="32" onerror="this.style.display='none'" />
                    <span class="final-seed">{champion.seed}</span>
                    <span class="final-name">{champion.effectiveAbbr}</span>
                  </div>
                )}
                <div class="final-defeated">defeated</div>
                {runnerUp && (
                  <div class="final-team">
                    <img src={`/images/logos/${runnerUp.effectiveAbbr}.png`} alt="" width="32" height="32" onerror="this.style.display='none'" />
                    <span class="final-seed">{runnerUp.seed}</span>
                    <span class="final-name">{runnerUp.effectiveAbbr}</span>
                  </div>
                )}
              </div>
            );
            return slug ? <a href={`/games/${year}/${slug}`} class="bracket-final-link">{finalContent}</a> : finalContent;
          })()}
        </div>

        <!-- RIGHT SIDE: semis → round1 (DOM order matches display order with flex-direction: row) -->
        <div class="bracket-side bracket-right">

          <!-- Semis (right) -->
          <div class="bracket-round bracket-round-semis">
            {(() => {
              const slug = buildSlug(rightSemiTop, rightSemiBottom, 16);
              const matchupContent = (
                <div class="bracket-matchup">
                  <div class="bracket-slot semi-slot top">
                    {rightSemiTop && (
                      <>
                        <img src={`/images/logos/${rightSemiTop.effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{rightSemiTop.seed}</span>
                        <span class="slot-name">{rightSemiTop.effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                  <div class="bracket-connector-v"></div>
                  <div class="bracket-slot semi-slot bottom">
                    {rightSemiBottom && (
                      <>
                        <img src={`/images/logos/${rightSemiBottom.effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{rightSemiBottom.seed}</span>
                        <span class="slot-name">{rightSemiBottom.effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                </div>
              );
              return slug ? <a href={`/games/${year}/${slug}`} class="bracket-matchup-link">{matchupContent}</a> : matchupContent;
            })()}
          </div>

          <!-- Round 1 (right) -->
          <div class="bracket-round">
            <!-- Top matchup -->
            {(() => {
              const slug = buildSlug(rightTop[0], rightTop[1], 15);
              const matchupContent = (
                <div class="bracket-matchup">
                  <div class="bracket-slot top">
                    {rightTop[0] && (
                      <>
                        <img src={`/images/logos/${rightTop[0].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{rightTop[0].seed}</span>
                        <span class="slot-name">{rightTop[0].effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                  <div class="bracket-connector-v"></div>
                  <div class="bracket-slot bottom">
                    {rightTop[1] && (
                      <>
                        <img src={`/images/logos/${rightTop[1].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{rightTop[1].seed}</span>
                        <span class="slot-name">{rightTop[1].effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                </div>
              );
              return slug ? <a href={`/games/${year}/${slug}`} class="bracket-matchup-link">{matchupContent}</a> : matchupContent;
            })()}
            <!-- Bottom matchup -->
            {(() => {
              const slug = buildSlug(rightBottom[0], rightBottom[1], 15);
              const matchupContent = (
                <div class="bracket-matchup">
                  <div class="bracket-slot top">
                    {rightBottom[0] && (
                      <>
                        <img src={`/images/logos/${rightBottom[0].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{rightBottom[0].seed}</span>
                        <span class="slot-name">{rightBottom[0].effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                  <div class="bracket-connector-v"></div>
                  <div class="bracket-slot bottom">
                    {rightBottom[1] && (
                      <>
                        <img src={`/images/logos/${rightBottom[1].effectiveAbbr}.png`} alt="" width="20" height="20" onerror="this.style.display='none'" />
                        <span class="slot-seed">{rightBottom[1].seed}</span>
                        <span class="slot-name">{rightBottom[1].effectiveAbbr}</span>
                      </>
                    )}
                  </div>
                </div>
              );
              return slug ? <a href={`/games/${year}/${slug}`} class="bracket-matchup-link">{matchupContent}</a> : matchupContent;
            })()}
          </div>

        </div><!-- end bracket-right -->

      </div><!-- end bracket-wrap -->

      {yearExhibitions.length > 0 && (
        <div class="section-rule">
          <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 1.25rem;">
            Exhibition Games
          </h2>
          <div style="display:grid; grid-template-columns:1fr; gap:1rem; max-width:72ch;">
            {yearExhibitions.map((e: any) => {
              const aWins = e.team_a.score > e.team_b.score;
              const bWins = e.team_b.score > e.team_a.score;
              return (
                <a class="matchup-card" href={`/games/${yearNum}/${e.slug}`}>
                  <div class="matchup-body">
                    <div class="matchup-teams">
                      <div class={`team-row ${aWins ? 'winner' : bWins ? 'loser' : 'tied'}`}>
                        <span style="display:flex;gap:4px;flex-shrink:0;">
                          {e.team_a.members.map((abbr: string) => (
                            <img src={`/images/logos/${abbr}.png`} alt={abbr} width="36" height="36"
                                 style="object-fit:contain;" onerror="this.style.display='none'" />
                          ))}
                        </span>
                        <span class="team-name">{e.team_a.display_name}</span>
                        <span class="team-score">{e.team_a.score.toFixed(2)}</span>
                      </div>
                      <div class={`team-row ${bWins ? 'winner' : aWins ? 'loser' : 'tied'}`}>
                        <span style="display:flex;gap:4px;flex-shrink:0;">
                          {e.team_b.members.map((abbr: string) => (
                            <img src={`/images/logos/${abbr}.png`} alt={abbr} width="36" height="36"
                                 style="object-fit:contain;" onerror="this.style.display='none'" />
                          ))}
                        </span>
                        <span class="team-name">{e.team_b.display_name}</span>
                        <span class="team-score">{e.team_b.score.toFixed(2)}</span>
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )}

      {draftBoards.length > 0 && (
        <div class="section-rule draft-section">
          <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 1.25rem;">
            Draft Board{draftBoards.length > 1 ? 's' : ''}
          </h2>

          {draftBoards.map((board) => (
            <div class="draft-board" style="margin: auto -5rem;">
              {draftBoards.length > 1 && (
                <h3 class="draft-board-label">{board.type.charAt(0).toUpperCase() + board.type.slice(1)} Draft</h3>
              )}
              <div class="draft-grid" style={`grid-template-columns: 2.5rem repeat(${board.numSlots}, minmax(5rem, 1fr));`}>
                {/* Header row */}
                <div class="draft-corner"></div>
                {board.headers.map(h => (
                  <div class="draft-col-header">
                    <img src={`/images/logos/${h.abbr}.png`} alt={h.abbr} width="28" height="28" onerror="this.style.display='none'" />
                    <span class="draft-col-abbr">{h.abbr}</span>
                  </div>
                ))}
                {/* Round rows */}
                {board.grid.map((row, ri) => (
                  <>
                    <div class="draft-round-label">Rd {ri + 1}</div>
                    {row.map(cell => cell ? (
                      <div class="draft-cell-wrap">
                        {cell.playerId ? (
                          <a href={`/players/${cell.playerId}`} class="draft-cell-link">
                            <div class="draft-cell" style={`--cell-surface:var(--color-${cell.colorVar}-surface);--cell-glow:var(--color-${cell.colorVar}-glow);`}>
                              <span class="cell-player">{cell.playerName}</span>
                              <span class="cell-pick-no">{cell.pickLabel}</span>
                              <span class="cell-pos">{cell.position}</span>
                            </div>
                          </a>
                        ) : (
                          <div class="draft-cell" style={`--cell-surface:var(--color-${cell.colorVar}-surface);--cell-glow:var(--color-${cell.colorVar}-glow);`}>
                            <span class="cell-player">{cell.playerName}</span>
                            <span class="cell-pick-no">{cell.pickLabel}</span>
                            <span class="cell-pos">{cell.position}</span>
                          </div>
                        )}
                        <div class="cell-bar">{cell.isTrade && cell.tradeToAbbr ? `→ ${cell.tradeToAbbr}` : ''}</div>
                      </div>
                    ) : (
                      <div class="draft-cell-empty"></div>
                    ))}
                  </>
                ))}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

  </div>
</Layout>


<style>
  /* ── Season summary ──────────────────────────────── */
  .season-summary :global(p) {
    margin-bottom: 1rem;
  }
  .season-summary :global(p:last-child) {
    margin-bottom: 0;
  }

  /* ── Bracket layout ──────────────────────────────── */
  .bracket-wrap {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    padding-bottom: 1rem;
  }

  .bracket-side {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .bracket-left {
    flex-direction: row;
  }

  /* Right side: DOM order is [semis, round1]; flex-direction row displays
     them left-to-right so semis is near center and round1 is at the far right. */
  .bracket-right {
    flex-direction: row;
    justify-content: flex-end;
  }

  /* Each round column stretches to fill its half of the bracket side */
  .bracket-round {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    gap: 0.5rem;
    padding: 0.5rem;
  }

  .bracket-round-semis {
    flex: 1;
    padding: 0.5rem;
  }

  .bracket-matchup-link {
    display: flex;
    flex-direction: column;
    cursor: pointer;
    text-decoration: none;
  }

  .bracket-matchup {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    position: relative;
  }

  /* Connector line between two slots in a matchup */
  .bracket-connector-v {
    width: 100%;
    height: 2px;
    background-color: var(--color-border);
    margin: 0;
    position: relative;
  }

  /* Vertical bar on the right side for left-bracket slots */
  .bracket-connector-v::after {
    content: '';
    position: absolute;
    right: -1px;
    top: -1.25rem;
    border-right: 2px solid var(--color-border);
    height: 2.5rem;
  }

  /* Vertical bar on the left side for right-bracket slots */
  .bracket-right .bracket-connector-v::after {
    left: -1px;
    right: auto;
    border-right: none;
    border-left: 2px solid var(--color-border);
  }

  /* Individual team slot */
  .bracket-slot {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.6rem;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    min-width: 110px;
    height: 2.5rem;
    font-size: 0.8rem;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .bracket-right .bracket-slot {
    flex-direction: row-reverse;
    text-align: right;
  }

  .bracket-slot img {
    object-fit: contain;
    flex-shrink: 0;
  }

  .slot-seed {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
    min-width: 14px;
    text-align: center;
  }

  .slot-name {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.8rem;
  }

  /* Semi-round slots have a solid border when populated, dashed when empty */
  .semi-slot {
    min-width: 90px;
  }

  .semi-slot:not(:has(img)) {
    background-color: color-mix(in srgb, var(--color-surface) 60%, transparent);
    border-style: dashed;
    color: var(--color-text-muted);
  }

  .bye-slot {
    border-color: var(--color-gold-dim);
  }

  .bye-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-gold-dim);
    margin-left: auto;
  }

  /* ── Final / Championship ─────────────────────── */
  .bracket-final-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    text-decoration: none;
  }

  .bracket-center {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1rem;
  }

  .bracket-final-label {
    margin-bottom: 0.75rem;
  }

  .bracket-final-slot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid var(--color-gold-glow);
    background-color: var(--color-gold-surface);
    padding: 1rem 1.25rem;
    min-width: 130px;
  }

  .final-team {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.5rem;
    width: 100%;
  }

  .final-team img {
    object-fit: contain;
    flex-shrink: 0;
  }

  .final-seed {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-gold-dim);
    min-width: 14px;
  }

  .final-name {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-gold);
  }

  .final-defeated {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 0.15rem 0;
  }

  /* ── Exhibition games ─────────────────────── */
  .matchup-card {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .matchup-body {
    display: flex;
    align-items: stretch;
  }

  .matchup-teams {
    flex: 1;
    min-width: 0;
  }

  .team-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    transition: background-color 0.1s ease;
  }

  .team-row + .team-row {
    border-top: 1px solid var(--color-border);
  }

  .team-row.winner {
    background-color: color-mix(in srgb, var(--color-surface) 80%, transparent);
  }

  .team-row.loser {
    opacity: 0.55;
  }

  .team-row.tied {
    background-color: transparent;
  }

  .team-logo {
    width: 36px;
    height: 36px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .team-name {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-primary);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .team-score {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    min-width: 3.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  .winner .team-score {
    color: var(--color-gold);
  }

  /* ── Draft board ──────────────────────────────────── */
  .draft-section {
    margin-top: 2.5rem;
  }

  .draft-board {
    /* responsive, no scroll */
  }

  .draft-board + .draft-board {
    margin-top: 2.5rem;
  }

  .draft-board-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0.75rem 0;
  }

  .draft-grid {
    display: grid;
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .draft-corner,
  .draft-col-header,
  .draft-round-label {
    background: var(--color-surface);
  }

  .draft-col-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.5rem 0.25rem;
    gap: 0.3rem;
  }

  .draft-col-abbr {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
  }

  .draft-round-label {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    color: var(--color-text-muted);
    font-weight: 600;
    writing-mode: vertical-lr;
    text-orientation: mixed;
  }

  .draft-cell-wrap {
    display: flex;
    flex-direction: column;
  }

  .draft-cell-link {
    flex: 1;
    display: flex;
    text-decoration: none;
    color: inherit;
  }

  .draft-cell-link .draft-cell {
    flex: 1;
  }

  .draft-cell-link:hover .draft-cell {
    filter: brightness(1.15);
  }

  .draft-cell {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    padding: 0.4rem 1.2rem 0.4rem 0.4rem;
    background: var(--cell-surface, var(--color-surface));
    border: 1px solid var(--cell-glow, var(--color-border));
    min-height: 4rem;
  }

  .cell-player {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.25;
    word-break: break-word;
  }

  .cell-pick-no {
    position: absolute;
    top: 0.2rem;
    right: 0.25rem;
    font-size: 0.6rem;
    color: var(--color-text-muted);
    font-family: var(--font-body);
  }

  .cell-pos {
    position: absolute;
    bottom: 0.2rem;
    right: 0.25rem;
    font-size: 0.6rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .cell-bar {
    height: 1.1rem;
    background: var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: right;
    padding: 0 0.35rem;
    font-size: 0.6rem;
    color: var(--color-text-primary);
  }

  .draft-cell-empty {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    min-height: 4rem;
    opacity: 0.25;
  }

  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 768px) {
    /* Standings: stack SCC above HCC */
    .standings-grid {
      grid-template-columns: 1fr !important;
    }

    .standings-grid .data-table {
      width: 100%;
    }

    .col-hide-mobile {
      display: none !important;
    }

    /* Bracket: vertical flow preserving internal side layouts */
    .bracket-wrap {
      flex-direction: column !important;
      align-items: stretch !important;
      overflow-x: hidden !important;
    }

    .bracket-side {
      flex: none !important;
      width: 100%;
    }

