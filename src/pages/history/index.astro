---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

// ── Fetch seasons ──────────────────────────────────────────────────────────
const { data: seasonRows, error: sErr } = await supabase
  .schema('scdfl')
  .from('seasons')
  .select('year, scc_champion, hcc_champion')
  .order('year');

if (sErr) throw new Error(`Seasons query failed: ${sErr.message}`);

// ── Fetch all franchise identities (including historical) ──────────────────
const { data: allFranchises, error: fErr } = await supabase
  .schema('scdfl')
  .from('franchises')
  .select('id, sleeper_id, abbr, name, owner, conf, colors, "from", "to"');

if (fErr || !allFranchises) throw new Error(`Franchises query failed: ${fErr?.message || 'No data returned'}`);

const franchises = allFranchises;
const activeFranchises = franchises.filter(f => f.to === null);
const activeBySleeperId = new Map(activeFranchises.map(f => [f.sleeper_id, f]));

// Resolve franchise identity for a given year
function franchiseForYear(sleeperId: string, yr: number) {
  return franchises.find(f =>
    f.sleeper_id === sleeperId && f.from <= yr && (f.to === null || f.to >= yr)
  );
}

// Resolve franchise identity by abbr for a given year
function franchiseByAbbrForYear(abbr: string, yr: number) {
  return franchises.find(f =>
    f.abbr === abbr && f.from <= yr && (f.to === null || f.to >= yr)
  );
}

// ── Fetch championship matchups (week 17, game_type = 1) ───────────────────
const { data: champMatchups, error: cmErr } = await supabase
  .schema('scdfl')
  .from('matchups')
  .select('year, roster_id_a, roster_id_b, score_a, score_b')
  .eq('week', 17)
  .eq('game_type', 1);

if (cmErr) throw new Error(`Championship matchups query failed: ${cmErr.message}`);

// ── Roman numeral helper ───────────────────────────────────────────────────
function toRoman(n: number): string {
  const vals = [1000,900,500,400,100,90,50,40,10,9,5,4,1];
  const syms = ['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I'];
  let result = '';
  for (let i = 0; i < vals.length; i++) {
    while (n >= vals[i]) { result += syms[i]; n -= vals[i]; }
  }
  return result;
}

// ── Build per-season display data ──────────────────────────────────────────
type FranchiseDisplay = { abbr: string; name: string; owner: string; conf: string };

type SeasonDisplay = {
  year: number;
  dynasty_bowl_label: string;
  scc: FranchiseDisplay | null;
  hcc: FranchiseDisplay | null;
  champion: FranchiseDisplay | null;
  runnerUp: FranchiseDisplay | null;
  championSleeperId: string | null;
};

const seasons: SeasonDisplay[] = [];

for (const s of seasonRows) {
  const champMatch = champMatchups.find(m => m.year === s.year);
  // Skip seasons with no championship matchup (e.g. in-progress season)
  if (!champMatch) continue;

  const bowlNum = s.year - 2020;

  // SCC/HCC champions — join by abbr for the year
  const sccF = franchiseByAbbrForYear(s.scc_champion, s.year);
  const hccF = franchiseByAbbrForYear(s.hcc_champion, s.year);

  // Dynasty Bowl winner/loser from week 17 matchup scores
  const aWins = champMatch.score_a > champMatch.score_b;
  const winnerSleeperId = String(aWins ? champMatch.roster_id_a : champMatch.roster_id_b);
  const loserSleeperId = String(aWins ? champMatch.roster_id_b : champMatch.roster_id_a);
  const winnerF = franchiseForYear(winnerSleeperId, s.year);
  const loserF = franchiseForYear(loserSleeperId, s.year);

  const toDisplay = (f: typeof allFranchises[0] | undefined): FranchiseDisplay | null =>
    f ? { abbr: f.abbr, name: f.name, owner: f.owner, conf: f.conf } : null;

  seasons.push({
    year: s.year,
    dynasty_bowl_label: `Dynasty Bowl ${toRoman(bowlNum)}`,
    scc: toDisplay(sccF),
    hcc: toDisplay(hccF),
    champion: toDisplay(winnerF),
    runnerUp: toDisplay(loserF),
    championSleeperId: winnerSleeperId,
  });
}

// ── Build championship record per franchise (attributed to current identity) ─
const championshipMap: Record<string, { count: number; years: number[] }> = {};

for (const season of seasons) {
  if (!season.championSleeperId) continue;
  const active = activeBySleeperId.get(season.championSleeperId);
  if (!active) continue;
  const key = active.abbr;
  if (!championshipMap[key]) championshipMap[key] = { count: 0, years: [] };
  championshipMap[key].count++;
  championshipMap[key].years.push(season.year);
}

const rollOfHonor = activeFranchises
  .filter(f => championshipMap[f.abbr])
  .map(f => ({ ...f, ...championshipMap[f.abbr] }))
  .sort((a, b) => Math.min(...a.years) - Math.min(...b.years));

// ── Conference win counts ──────────────────────────────────────────────────
const hccWins = seasons.filter(s => s.champion?.conf === 'HCC').length;
const sccWins = seasons.filter(s => s.champion?.conf === 'SCC').length;
---

<Layout title="League History" description="Season-by-season history, dynasty bowl results, and franchise records for the Sixth City Dynasty Football League.">

  <div style="max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem 0;">

    <!-- Page header -->
    <div style="padding-bottom: 2.5rem; border-bottom: 1px solid var(--color-border);">
      <p class="section-label">League Archive</p>
      <h1 class="page-title">History &amp; Records</h1>
      <p class="page-subheader" style="margin-top: 0.75rem;">
        The Sixth City Dynasty Football League was founded in 2021 as a
        branch off of a standard redraft league with origins in the Sigma
        Phi Epsilon Ohio Zeta chapter. Rooted in Cleveland, Sixth City is
        host to members throughout the state of Ohio.
      <br><br>
        Sixth City celebrates continuity and creativity. Franchises carry
        their own legacies from year to year, and they carry the glory and
        ignominy that comes with those legacies. Bowl Games and Rivalry Weeks
        are designed to spotlight both the dynamics between members of the
        league and the fictional threads that bind franchises historically
        and geographically. Members concoct experimental formats like 2v2
        Tag-Team and One-vs-Everyone matchups. History is preserved and
        celebrated with the advent of Throwback Week and the Hall of Fame.
      <br><br>
        What began as a group of fraternity buddies coming together to enjoy
        the game of football has grown into a vibrant sports community,
        contributing to a league that has become an entire universe rich
        with history, rivalries, and traditions.
      </p>
    </div>

    <!-- Season-by-season table -->
    <div style="margin-top: 3rem;">
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--color-text-primary);">
        Season Results
      </h2>
      <p class="page-whisper" style="margin-bottom: 1.5rem;">Click on a season's row for more detail.</p>
      <div style="overflow-x: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Season</th>
              <th class="col-hide-mobile">SCC Champion</th>
              <th class="col-hide-mobile">HCC Champion</th>
              <th class="col-hide-mobile">Dynasty Bowl</th>
              <th>Champion</th>
              <th class="col-hide-mobile">Runner-Up</th>
              <th class="col-see-more"></th>
            </tr>
          </thead>
          <tbody>
            {seasons.slice().reverse().map(season => (
              <tr
                onclick={`window.location='/history/${season.year}'`}
                style="cursor: pointer;"
                class="history-row"
              >
                <td style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--color-gold);">{season.year}</td>
                <td class="col-hide-mobile">
                  <span style="color: var(--color-text-primary);">
                    {season.scc?.name}
                  </span>
                  <span style="display: block; font-size: 0.75rem; color: var(--color-text-muted);">{season.scc?.owner}</span>
                </td>
                <td class="col-hide-mobile">
                  <span style="color: var(--color-text-primary);">
                    {season.hcc?.name}
                  </span>
                  <span style="display: block; font-size: 0.75rem; color: var(--color-text-muted);">{season.hcc?.owner}</span>
                </td>
                <td class="col-hide-mobile" style="font-size: 0.85rem; color: var(--color-text-secondary);">{season.dynasty_bowl_label}</td>
                <td class="winner-cell">
                  <span style="color: var(--color-gold);">
                    {season.champion?.name}
                  </span>
                  <span style="display: block; font-size: 0.75rem; font-weight: 400; color: var(--color-gold-dim);">{season.champion?.owner}</span>
                </td>
                <td class="col-hide-mobile">
                  <span style="color: var(--color-text-secondary);">
                    {season.runnerUp?.name}
                  </span>
                  <span style="display: block; font-size: 0.75rem; color: var(--color-text-muted);">{season.runnerUp?.owner}</span>
                </td>
                <td class="col-see-more">See more &#8594;</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Conference record -->
    <div style="margin-top: 3rem; display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background-color: var(--color-border);">
      <div style="background-color: var(--color-surface); padding: 1.75rem; text-align: center;">
        <p style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.5rem;">HCC Dynasty Bowls</p>
        <p style="font-family: var(--font-display); font-size: 3rem; font-weight: 700; color: #d4906e; line-height: 1;">{hccWins}</p>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.25rem;">House of Commons Conference</p>
      </div>
      <div style="background-color: var(--color-surface); padding: 1.75rem; text-align: center;">
        <p style="font-family: var(--font-body); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 0.5rem;">SCC Dynasty Bowls</p>
        <p style="font-family: var(--font-display); font-size: 3rem; font-weight: 700; color: #7eb8d8; line-height: 1;">{sccWins}</p>
        <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-top: 0.25rem;">Senatorial Canadian Conference</p>
      </div>
    </div>
    <p style="font-size: 0.8rem; color: var(--color-text-muted); text-align: center; margin-top: 0.75rem;">
      {hccWins > sccWins
        ? `HCC leads the all-time Dynasty Bowl series ${hccWins}–${sccWins}.`
        : sccWins > hccWins
        ? `SCC leads the all-time Dynasty Bowl series ${sccWins}–${hccWins}.`
        : `The all-time Dynasty Bowl series is tied ${hccWins}–${sccWins}.`}
      {' '}TOR (2024) is the only SCC franchise to claim a championship.
    </p>

    <!-- Roll of Honor -->
    <div class="section-rule">
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem;">
        Championship Roll of Honor
      </h2>
      <div style="border: 1px solid var(--color-border);">
        {rollOfHonor.map((franchise, i) => (
          <div style={`display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.25rem; ${i !== 0 ? 'border-top: 1px solid var(--color-border);' : ''} `}>
            <div style="display: flex; align-items: center; gap: 1rem;">
              <img
                src={`/images/logos/${franchise.abbr}.png`}
                alt=""
                width="32"
                height="32"
                style="object-fit: contain; flex-shrink: 0;"
                onerror="this.style.display='none'"
              />
              <div>
                <a href={`/franchises/${franchise.abbr}`} style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--color-text-primary);">
                  {franchise.name}
                </a>
                <span style="display: block; font-size: 0.75rem; color: var(--color-text-muted);">{franchise.abbr} &bull; {franchise.owner} &bull; <span class={`label-badge badge-${franchise.conf.toLowerCase()}`}>{franchise.conf}</span></span>
              </div>
            </div>
            <div style="text-align: right;">
              <div style="display: flex; align-items: center; gap: 0.4rem; justify-content: flex-end;">
                {Array.from({ length: franchise.count }).map(() => (
                  <span style="color: var(--color-gold); font-size: 1.25rem;">&#11042;</span>
                ))}
              </div>
              <p style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.2rem;">
                {franchise.years.join(', ')}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Playoff format notes -->
    <div class="section-rule">
      <h2 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; margin-bottom: 1.25rem;">Playoff Format</h2>
      <div class="playoff-format-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
        <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.5rem;">
          <p class="section-label">2021–2022</p>
          <p style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.6;">
            8 teams qualified — 4 per conference. Conference-bracket format with a cross-conference championship, guaranteeing an SCC vs. HCC Dynasty Bowl matchup.
          </p>
        </div>
        <div style="background-color: var(--color-surface); border: 1px solid var(--color-border); padding: 1.5rem;">
          <p class="section-label">2023–Present</p>
          <p style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.6;">
            Playoff field contracted to 7 teams. Seeds 1 and 2 are reserved for the SCC and HCC conference champions. The 1-seed earns a first-round bye. Seeds 3 through 7 are at-large by record.
          </p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .history-row:hover td {
    background-color: color-mix(in srgb, var(--color-gold) 5%, transparent);
  }

  /* See more column — desktop: hidden; mobile: visible */
  .col-see-more {
    display: none;
  }

  @media (max-width: 768px) {
    /* Hide non-essential table columns */
    .col-hide-mobile {
      display: none;
    }

    /* Show and style the "See more" column */
    .col-see-more {
      display: table-cell;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--color-gold-dim);
      white-space: nowrap;
      text-align: right;
    }

    /* Playoff format: single column */
    .playoff-format-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>
